---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccompagnementsTeaser from "../components/home/AccompagnementsTeaser.astro";
import "../styles/pages/index.css";

const description =
  "Maison Foébé est un espace structuré du self-care pour comprendre ce qui s’épuise, repérer ce qui déborde et choisir un geste concret.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://maisonfoebe.fr/#website",
      url: "https://maisonfoebe.fr",
      name: "Maison Foébé",
      description,
      inLanguage: "fr",
    },
    {
      "@type": "Organization",
      "@id": "https://maisonfoebe.fr/#organization",
      name: "Maison Foébé",
      url: "https://maisonfoebe.fr",
      logo: {
        "@type": "ImageObject",
        url: "https://maisonfoebe.fr/images/logo-foebe.png",
      },
      sameAs: [
        "https://www.instagram.com/maisonfoebe",
        "https://www.tiktok.com/@maisonfoebe",
        "https://fr.pinterest.com/maisonfoebe/",
      ],
      description,
    },
  ],
};
---

<BaseLayout
  title="Maison Foébé · Le self-care comme compétence"
  description={description}
  canonical="https://maisonfoebe.fr"
  ogTitle="Maison Foébé · Espace du self-care structuré"
  ogDescription={description}
  twitterTitle="Maison Foébé · espace structuré du self-care"
  twitterDescription={description}
  bodyClass="page-index"
  jsonLd={jsonLd}
>
<main id="mainContent" tabindex="-1">

<section aria-labelledby="home-start-title" class="home-start-section home-start-hero" id="commencer">
<div class="home-start-inner">
<div class="home-start-head index-motion-intro" data-index-motion="intro">
<span class="home-start-eyebrow">Maison Foébé te souhaite la bienvenue ✨</span>
<h1 class="home-start-title" id="home-start-title">Tu <span class="foebe-word foebe-word--warm">fonctionnes</span>, mais tu ne récupères <span class="foebe-word foebe-word--rose">plus vraiment.</span></h1>
<p class="home-start-signature">Ici, le <span class="foebe-highlight foebe-highlight--warm">self-care</span> devient une compétence : apprendre à <span class="foebe-highlight foebe-highlight--rose">se lire</span>, <span class="foebe-highlight foebe-highlight--red">se réguler</span>, puis <span class="foebe-highlight foebe-highlight--warm">avancer</span> avec plus de douceur.</p>
</div>
</div>
</section>
<section aria-labelledby="home-capacity-title" class="home-capacity-section" id="capacite-action">
<div class="home-capacity-inner">
<div class="home-capacity-guide index-motion-panel" data-index-motion="panel">
<span class="home-capacity-eyebrow">Le self-care comme compétence</span>
<h2 class="home-capacity-title" id="home-capacity-title">Foébé t’aide à retrouver une <em>marge d’action</em> dans ton self-care.</h2>
<ul aria-label="Les quatre capacités que Maison Foébé aide à retrouver" class="home-capacity-path">
<li><span>Reconnaître tes signaux</span></li>
<li><span>Comprendre ce qui se déséquilibre</span></li>
<li><span>Choisir un geste adapté à ta réalité</span></li>
<li><span>Réévaluer sans te juger</span></li>
</ul>
</div>
</div>
</section>
<div aria-hidden="true" class="section-fade section-fade-down fade-capacity-entry"></div>
<section aria-labelledby="home-entry-title" class="home-entry-section" id="portes-entree">
<div class="home-start-inner">
<div aria-label="Trois portes pour commencer" class="home-choice-guide">
<h2 class="home-choice-kicker" id="home-entry-title">Trois portes d’entrée</h2>
<p>Pour <span class="foebe-color foebe-color--warm">te situer</span>, <span class="foebe-color foebe-color--red">redescendre</span> ou <span class="foebe-color foebe-color--rose">comprendre ce qui se joue</span>.</p>
<p class="home-explore-note">Commence par ce qui te parle le plus, il n'y a pas d'ordre précis.</p>
</div>
<div aria-label="Choisir par où commencer dans Maison Foébé" class="home-start-grid home-start-grid--primary">
<a aria-label="Faire l’Échelle Foébé" class="home-start-card home-start-card--primary index-motion-card" data-index-motion="card" href="echelle-foebe.html">
<div aria-hidden="true" class="home-visual home-visual--echelle-anim">
<span aria-hidden="true" class="foebe-balance-scene">
<svg class="foebe-balance-svg" focusable="false" role="presentation" viewBox="38 34 244 122">
<g class="foebe-balance-stand">
<path class="foebe-balance-base" d="M112 147 H208"></path>
<path class="foebe-balance-stem" d="M160 55 V147"></path>
<circle class="foebe-balance-pivot" cx="160" cy="55" r="9"></circle>
</g>
<g class="foebe-balance-rock">
<path class="foebe-balance-beam" d="M68 55 H252"></path>
<g class="foebe-balance-side foebe-balance-side--left">
<path class="foebe-balance-cord" d="M90 55 V103"></path>
<path class="foebe-balance-pan" d="M58 103 Q90 122 122 103"></path>
<circle class="foebe-balance-weight foebe-balance-weight--light" cx="90" cy="95" r="8"></circle>
</g>
<g class="foebe-balance-side foebe-balance-side--right">
<path class="foebe-balance-cord" d="M230 55 V103"></path>
<path class="foebe-balance-pan" d="M198 103 Q230 122 262 103"></path>
<circle class="foebe-balance-weight foebe-balance-weight--one" cx="230" cy="95" r="8"></circle>
<circle class="foebe-balance-weight foebe-balance-weight--two" cx="218" cy="91" r="8"></circle>
<circle class="foebe-balance-weight foebe-balance-weight--three" cx="242" cy="91" r="8"></circle>
</g>
</g>
</svg>
</span>
</div>
<span class="home-start-num">01 · Me situer</span>
<h3>Je ne sais pas <span class="foebe-color foebe-color--warm">ce qui me pèse</span> le plus…</h3>
<p>21 affirmations pour repérer les zones qui demandent ton attention en ce moment.</p>
<span class="home-start-link">Commencer l’Échelle Foébé →</span>
</a>
<a aria-label="Lancer la respiration guidée" class="home-start-card home-start-card--primary index-motion-card" data-index-motion="card" href="respiration.html">
<div aria-hidden="true" class="home-visual home-visual--respiration" id="breathPreview">
<span class="home-breath-preview">
<span aria-hidden="true" class="home-breath-direction">↑</span>
<span class="home-breath-track">
<span class="home-breath-ball" id="breathBall"></span>
</span>
<span aria-hidden="true" class="home-breath-direction">↓</span>
<span class="home-breath-label" id="breathLabel">Inspire</span>
</span>
</div>
<span class="home-start-num">02 · Me recentrer</span>
<h3>J’ai besoin de <span class="foebe-color foebe-color--red">redescendre maintenant.</span></h3>
<p>Des exercices courts de respiration guidée pour retrouver un peu d’appui.</p>
<span class="home-start-link">Me recentrer maintenant →</span>
</a>
<a aria-label="Explorer les 7 zones du self-care" class="home-start-card home-start-card--primary index-motion-card" data-index-motion="card" href="zones.html">
<div aria-hidden="true" class="home-visual home-visual--zones-anim">
<svg class="zones-wave-svg" preserveAspectRatio="none" viewBox="0 0 360 136" xmlns="http://www.w3.org/2000/svg">
<path class="wave-path-1" d="M0,60 C60,35 120,85 180,60 C240,35 300,85 360,60 L360,136 L0,136 Z" fill="rgba(187,126,96,.14)"></path>
<path class="wave-path-2" d="M0,80 C50,55 110,100 180,78 C240,58 300,100 360,80 L360,136 L0,136 Z" fill="rgba(187,126,96,.09)"></path>
<path class="wave-path-3" d="M0,96 C70,76 130,110 200,96 C270,82 320,108 360,96 L360,136 L0,136 Z" fill="rgba(240,234,231,.07)"></path>
</svg>
<span aria-hidden="true" class="foebe-zone-node-map">
<i></i><i></i><i></i><i></i><i></i><i></i><i></i>
</span>
</div>
<span class="home-start-num">03 · Explorer les zones</span>
<h3>Je veux <span class="foebe-color foebe-color--warm">comprendre ce qui se joue.</span></h3>
<p>Corps, mental, énergie, émotions, environnement, relations, sens. Commence par la zone qui te parle.</p>
<span class="home-start-link">Explorer les zones →</span>
</a>
</div>
<p class="home-secondary-intro">Pour aller plus loin dans ta lecture.</p>
<div aria-label="Accès complémentaires Maison Foébé" class="home-secondary-access">
<a aria-label="Explorer la Boussole Foébé" class="home-secondary-card index-motion-card" data-index-motion="card" href="boussole.html">
<span aria-hidden="true" class="home-secondary-icon">
<span class="boussole-wrap">
<span class="boussole-arrow"></span>
</span>
</span>
<span class="home-secondary-content">
<span class="home-secondary-kicker">Parcours guidé</span>
<strong>Explorer la Boussole</strong>
<span>Pour reconnaître une situation précise et choisir une direction.</span>
</span>
<span aria-hidden="true" class="home-secondary-arrow">→</span>
</a>
<a aria-label="Ouvrir le Dictionnaire Foébé" class="home-secondary-card index-motion-card" data-index-motion="card" href="dictionnaire.html">
<span aria-hidden="true" class="home-secondary-icon home-secondary-icon--biblio">
<span class="biblio-line"><span id="bibliotype"></span><span class="biblio-cursor"></span></span>
</span>
<span class="home-secondary-content">
<span class="home-secondary-kicker">Ressource</span>
<strong>Dictionnaire Foébé</strong>
<span>Pour mettre des mots précis sur le soin, le corps et le self-care.</span>
</span>
<span aria-hidden="true" class="home-secondary-arrow">→</span>
</a>
</div>
<div aria-labelledby="home-vocab-title" class="home-vocab reveal reveal-delay-1 index-motion-panel" data-index-motion="panel">
<span class="home-vocab-kicker">Quatre mots à distinguer</span>
<h2 class="home-vocab-title" id="home-vocab-title">Self-care, skincare, bodycare et haircare <em>n’ont pas le même rôle.</em></h2>

<p class="home-vocab-intro">
  Foébé parle de self-care, de peau, de corps et de cheveux, mais ces mots ne désignent pas la même chose. Elle relie ces dimensions sans les confondre : le soin devient un point d’entrée pour mieux se lire, pas une injonction à se corriger.
</p>

<h3 class="home-vocab-list-title" id="home-vocab-list-title">
  Quatre mots pour mieux se repérer
</h3>

<div
  aria-labelledby="home-vocab-list-title"
  class="home-vocab-list vocab-accordion"
>
  <div class="home-vocab-item">
    <button
      aria-controls="vocab-selfcare"
      aria-expanded="false"
      class="home-vocab-trigger"
      data-home-vocab-target="vocab-selfcare"
      type="button"
    >
      <span>Self-care</span>
    </button>

    <div
      aria-hidden="true"
      aria-label="Définition du self-care"
      class="home-vocab-panel"
      id="vocab-selfcare"
      role="region"
    >
      La manière dont tu prends soin de ton équilibre : corps, mental, émotions, énergie, environnement, relations et sens.
    </div>
  </div>

  <div class="home-vocab-item">
    <button
      aria-controls="vocab-skincare"
      aria-expanded="false"
      class="home-vocab-trigger"
      data-home-vocab-target="vocab-skincare"
      type="button"
    >
      <span>Skincare</span>
    </button>

    <div
      aria-hidden="true"
      aria-label="Définition du skincare"
      class="home-vocab-panel"
      id="vocab-skincare"
      role="region"
    >
      Les gestes et actifs liés à la peau : barrière cutanée, hydratation, exfoliation, sensibilité, texture et confort.
    </div>
  </div>

  <div class="home-vocab-item">
    <button
      aria-controls="vocab-bodycare"
      aria-expanded="false"
      class="home-vocab-trigger"
      data-home-vocab-target="vocab-bodycare"
      type="button"
    >
      <span>Bodycare</span>
    </button>

    <div
      aria-hidden="true"
      aria-label="Définition du bodycare"
      class="home-vocab-panel"
      id="vocab-bodycare"
      role="region"
    >
      Les gestes liés au corps : nettoyage, hydratation, nutrition, exfoliation, confort, toucher et relation au corps.
    </div>
  </div>

  <div class="home-vocab-item">
    <button
      aria-controls="vocab-haircare"
      aria-expanded="false"
      class="home-vocab-trigger"
      data-home-vocab-target="vocab-haircare"
      type="button"
    >
      <span>Haircare</span>
    </button>

    <div
      aria-hidden="true"
      aria-label="Définition du haircare"
      class="home-vocab-panel"
      id="vocab-haircare"
      role="region"
    >
      Les gestes liés aux cheveux et au cuir chevelu : hydratation, porosité, casse, clarification, protection et routine.
    </div>
  </div>
</div>


</section>
<div aria-hidden="true" class="section-fade section-fade-down fade-home-start-reco"></div>

<section aria-labelledby="reco-title" class="reco-section" id="decouvrir">
<div class="reco-inner">
<div class="reco-header reveal index-motion-panel" data-index-motion="panel">
<p class="section-step"><span>01</span></p>
<span class="section-eyebrow">Tu reconnais cette situation ?</span>
<h2 class="reco-title" id="reco-title">
      Tu peux <span class="foebe-highlight foebe-highlight--warm">continuer à fonctionner</span><br/>
      tout en commençant à <span class="foebe-highlight foebe-highlight--red">t’épuiser.</span>
</h2>
<p class="reco-intro">On le voit chez des personnes qui continuent à fonctionner : elles organisent, livrent, tiennent. Concrètement, cela peut se reconnaître à ces signaux.</p>
</div>
<div class="reco-grid reveal reveal-delay-1">
<div class="reco-item index-motion-signal" data-index-motion="signal">
<span aria-hidden="true" class="reco-dash">—</span>
<p>Une <span class="foebe-color foebe-color--warm">fatigue chronique</span> que le repos ne résout pas vraiment.</p>
</div>
<div class="reco-item index-motion-signal" data-index-motion="signal">
<span aria-hidden="true" class="reco-dash">—</span>
<p>Un <span class="foebe-color foebe-color--rose">mental qui ne s’arrête plus</span>, même dans les moments calmes.</p>
</div>
<div class="reco-item index-motion-signal" data-index-motion="signal">
<span aria-hidden="true" class="reco-dash">—</span>
<p>Une adaptation si ancienne qu’on ne sait plus <span class="foebe-color foebe-color--red">ce dont on a besoin.</span></p>
</div>
<div class="reco-item index-motion-signal" data-index-motion="signal">
<span aria-hidden="true" class="reco-dash">—</span>
<p>Le sentiment que <span class="foebe-color foebe-color--rose">quelque chose ne va pas</span>, sans pouvoir nommer quoi.</p>
</div>
</div>
<p class="editorial-bridge">Tu n’as pas besoin d’attendre de t’effondrer pour <span class="foebe-highlight foebe-highlight--warm">prendre au sérieux ce que tu ressens.</span></p>
</div>
</section>
<section aria-labelledby="founder-title" class="founder-section reveal index-motion-panel" data-index-motion="panel" id="pourquoi-foebe">
<div class="founder-inner">
<p class="section-step"><span>02</span></p>
<span class="section-eyebrow">Pourquoi Foébé</span>
<h2 class="section-title" id="founder-title">
      Un cadre né du <span class="foebe-word foebe-word--warm">terrain.</span>
</h2>
<div class="founder-copy">
<p>Foébé part d’un constat simple : on peut <span class="foebe-color foebe-color--warm">continuer à fonctionner</span> longtemps tout en commençant déjà à s’épuiser.</p>
<p>La méthode transforme ce constat en repères concrets : <span class="foebe-highlight foebe-highlight--rose">lire ses signaux</span>, <span class="foebe-color foebe-color--red">comprendre ses besoins</span> et retrouver un self-care plus stable.</p>
<p>Elle a été conçue par une docteure en psychologie et ergonome, spécialisée en <span class="foebe-color foebe-color--warm">santé au travail.</span></p>
</div>
<div class="founder-ctas">
<a class="btn-founder-primary" href="methode.html">Découvrir la méthode →</a>
<a class="btn-founder-secondary" href="a-propos.html">À propos →</a>
</div>
</div>
</section>
<AccompagnementsTeaser />
</main>

  <script src="../scripts/index.js"></script>
</BaseLayout>
