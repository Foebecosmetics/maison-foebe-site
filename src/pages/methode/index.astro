---
import GuidedNextSteps from '../../components/GuidedNextSteps.astro';
import GuidedFaq from '../../components/GuidedFaq.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/pages/methode.css';

const methodeFaq = [
  { question: 'La méthode Foébé est-elle un test clinique ?', answer: 'Non. Elle organise des repères issus de la psychologie, de l’ergonomie et des facteurs humains, mais elle ne remplace ni une évaluation clinique ni un diagnostic.' },
  { question: 'Pourquoi ne pas donner un score unique ?', answer: 'Parce qu’un même score peut masquer des fonctionnements très différents. Foébé préfère une lecture située : ce qui pèse, ce qui soutient et la marge d’action disponible maintenant.' },
  { question: 'Est-ce du coaching ou une thérapie ?', answer: 'Non. La méthode n’impose pas d’objectif de performance et ne traite pas un trouble. Elle aide à comprendre un fonctionnement et à choisir un premier ajustement soutenable.' },
];
---

<BaseLayout
  title="Méthode Foébé · Psychologie, ergonomie et self-care"
  description="La méthode Foébé relie psychologie, ergonomie, charge mentale et récupération pour lire 7 dimensions du self-care sans diagnostic ni injonction."
  canonical="https://maisonfoebe.fr/methode/"
  ogTitle="La méthode Foébé · Lire ce qui s’épuise"
  ogDesc="Psychologie, ergonomie et facteurs humains au service d’une lecture structurée du self-care, sans score ni injonction."
  ogImage="https://maisonfoebe.fr/images/og-methode.png"

  ogImageAlt="Illustration abstraite des repères reliés par la méthode Foébé"
>
<main id="mainContent" tabindex="-1"><section class="hero">
<div class="method-hero-grid"><div class="method-hero-copy">
<h1 class="hero-title reveal reveal-delay-1">
      La méthode Foébé :<br/><em>sur quoi repose sa lecture</em>
</h1>
<span class="hero-rule reveal reveal-delay-2"></span>
<p class="hero-body reveal reveal-delay-2">Foébé propose une lecture structurée du self-care à partir du vécu réel.</p><p class="hero-benefit reveal reveal-delay-3">L’objectif est simple : aider à lire plus clairement son propre self-care et à mieux comprendre son fonctionnement.</p>
<div aria-label="Repères de posture Foébé" class="hero-not reveal reveal-delay-3">
<button class="hero-chip" data-chip-text="Foébé ne te pousse pas à performer, à devenir meilleure ou à atteindre des objectifs. La méthode aide d’abord à lire ce qui coûte, ce qui se répète, puis à choisir un geste tenable." data-chip-title="Pas du coaching" type="button">Pas du coaching</button>
<button class="hero-chip" data-chip-text="Foébé ne pose pas de diagnostic et ne remplace pas un suivi thérapeutique. C’est un espace d’observation pour mieux nommer son fonctionnement et repérer où commencer." data-chip-title="Pas de la thérapie" type="button">Pas de la thérapie</button>
<button class="hero-chip" data-chip-text="Foébé ne propose pas une routine miracle ou des conseils universels. Elle part des signaux, de la charge, du contexte réel et transforme le flou en repères concrets." data-chip-title="Pas du wellness générique" type="button">Pas du wellness générique</button>
<button class="hero-chip" data-chip-text="Foébé organise le self-care comme une compétence : observer, comprendre, structurer, stabiliser. Le but n’est pas de tout changer, mais de savoir où regarder en premier." data-chip-title="Un espace structuré du self-care" type="button">Un espace structuré du self-care</button>
</div>
</div><figure aria-hidden="true" class="method-visual reveal reveal-delay-1">
<div class="method-stage">
<svg class="method-svg" focusable="false" viewbox="0 0 400 400">
<defs>
<lineargradient id="methodGradient" x1="0" x2="1" y1="0" y2="1">
<stop offset="0%" stop-color="#BB7E60"></stop>
<stop offset="52%" stop-color="#C45279"></stop>
<stop offset="100%" stop-color="#C34234"></stop>
</lineargradient>
</defs>
<circle class="method-track" cx="200" cy="200" r="150"></circle>
<circle class="method-track method-track--inner" cx="200" cy="200" r="100"></circle>
<path class="method-flow" d="M200 50 C285 50 350 115 350 200 C350 285 285 350 200 350 C115 350 50 285 50 200 C50 115 115 50 200 50 Z"></path>
<circle class="method-orbit-dot" cx="200" cy="50" r="6"></circle>
</svg>
<div class="method-core"><strong>F</strong></div>
<span class="method-node method-node--1">01</span>
<span class="method-node method-node--2">02</span>
<span class="method-node method-node--3">03</span>
<span class="method-node method-node--4">04</span>
</div>
</figure></div>
</section><section class="section bg2">
<div class="section-inner">
<div class="reveal">
<span class="section-eyebrow">Fondements scientifiques</span>
<h2 class="section-title">Trois repères.<br/><em>Une lecture intégrée.</em></h2>
<p class="section-body">Foébé s’appuie sur trois modèles de lecture complémentaires pour relier ce qui se vit, ce qui se répète et ce qui devient coûteux.</p>
</div>
<div class="modeles-grid reveal reveal-delay-1">
<div class="modele-item">
<span class="modele-num">Modèle 01</span>
<h3 class="modele-name">Big Five<br/><em>Costa &amp; McCrae (1985)</em></h3>
<span class="modele-rule"></span>
<p class="modele-desc">
     Le modèle des cinq grands traits de personnalité situe le fonctionnement d'une personne sur cinq dimensions relativement stables : ouverture, conscienciosité, extraversion, agréabilité, névrosisme.<br/><br/>
<strong>Ce qu'il permet de voir :</strong> les tendances de fond, plutôt que les états passagers ; ce qui structure la manière dont une personne répond au stress, à la charge et aux relations.
  </p>
<a class="modele-link" href="https://www.psychomedia.qc.ca/lexique/definition/modele-des-cinq-facteurs-de-la-personnalite" rel="noopener noreferrer" target="_blank">En savoir plus</a>
</div>
<div class="modele-item">
<span class="modele-num">Modèle 02</span>
<h3 class="modele-name">Théorie des valeurs<br/><em>Schwartz (1992)</em></h3>
<span class="modele-rule"></span>
<p class="modele-desc">
       Une théorie des dix valeurs fondamentales, organisées selon des relations de compatibilité et de tension, et structurées autour de grands axes comme ouverture au changement versus conservation, et transcendance de soi versus affirmation de soi.<br/><br/>
<strong>Ce qu'il permet de voir :</strong> les motivations profondes, les tensions entre valeurs et les écarts possibles entre ce qu'une personne valorise et ce qu'elle vit au quotidien.
  </p>
<a class="modele-link" href="https://shs.cairn.info/revue-les-cahiers-internationaux-de-psychologie-sociale-2016-4-page-427?lang=fr" rel="noopener noreferrer" target="_blank">En savoir plus</a>
</div>
<div class="modele-item">
<span class="modele-num">Modèle 03</span>
<h3 class="modele-name">Charge cognitive<br/> <em>Sweller (1988)</em></h3>
<span class="modele-rule"></span>
<p class="modele-desc">
    Une lecture du fonctionnement à partir de l'effort mental, des ressources attentionnelles, des contraintes situationnelles et des ajustements mis en place pour tenir dans la durée.<br/><br/>
<strong>Ce qu'il permet de voir :</strong> où la charge devient coûteuse, comment la personne compense, et à quel moment les ressources disponibles ne suffisent plus.
  </p>
<div class="modele-links">
<a class="modele-link" href="https://portaildocumentaire.inrs.fr/Default/doc/SYRACUSE/82847/une-approche-de-l-ergonomie-cognitive-1re-partie-2e-partie-methodes-psychologiques-en-ergonomie-3e-p?_lg=fr-FR" rel="noopener noreferrer" target="_blank">En savoir plus</a>
</div>
</div>
</div>
</div>
</section><section class="section">
<div class="section-inner">
<div class="reveal">
<span class="section-eyebrow">Les quatre mouvements</span>
<h2 class="section-title">Comment la méthode<br/><em>fonctionne concrètement ?</em></h2>
<p class="section-body">La méthode Foébé ne cherche pas une cause unique. Elle observe, relie, puis structure ce qui se passe pour rendre la lecture plus claire.

</p>
</div>
<div class="etapes-list mouvements-list reveal reveal-delay-1">
<div class="etape mouvement-etape">
<div class="etape-num-col"><span class="etape-num">01</span></div>
<div class="etape-content">
<h3 class="etape-title"><em>Observer</em></h3>
<p class="etape-desc">Observer, ce n'est pas seulement repérer un symptôme. C'est voir où l'énergie se perd, où le corps insiste, où le mental compense, où la relation à soi devient mécanique.</p>
<p class="etape-plus">La méthode transforme une sensation floue en signaux lisibles. Ce qui ressemblait à "juste de la fatigue" devient une information située.</p>
</div>
</div>
<div class="etape mouvement-etape">
<div class="etape-num-col"><span class="etape-num">02</span></div>
<div class="etape-content">
<h3 class="etape-title"><em>Comprendre</em></h3>
<p class="etape-desc">Comprendre, ce n'est pas chercher une cause unique. C'est relier les rythmes, les contraintes, les valeurs, les automatismes et les zones qui se répondent.</p>
<p class="etape-plus">La lecture Foébé évite le raccourci. Elle identifie ce qui déclenche le déséquilibre et ce qui l'entretient, sans réduire la personne à un profil figé.</p>
</div>
</div>
<div class="etape mouvement-etape">
<div class="etape-num-col"><span class="etape-num">03</span></div>
<div class="etape-content">
<h3 class="etape-title"><em>Structurer</em></h3>
<p class="etape-desc">Structurer, ce n'est pas imposer une routine idéale. C'est construire des repères qui tiennent dans la vraie vie, avec l'énergie disponible, le contexte réel et la manière de fonctionner de la personne.</p>
<p class="etape-plus">La méthode propose des leviers concrets, classés et hiérarchisés, pour passer d'une prise de conscience à un cadre utilisable.</p>
</div>
</div>
<div class="etape mouvement-etape">
<div class="etape-num-col"><span class="etape-num">04</span></div>
<div class="etape-content">
<h3 class="etape-title"><em>Stabiliser</em></h3>
<p class="etape-desc">Stabiliser, ce n'est pas tout résoudre. C'est installer des appuis simples et répétables, pour ne pas repartir de zéro à chaque difficulté rencontrée.</p>
<p class="etape-plus">La méthode cherche moins l'effet immédiat que la continuité : ce qui aide à revenir à soi, à récupérer, puis à maintenir un équilibre plus lisible.</p>
</div>
</div>
</div>
</div>
</section><section class="posture-section bg2">
<div class="posture-inner">
<div class="reveal">
<span class="section-eyebrow">Ce que Foébé s'engage à ne pas faire</span>
<h2 class="section-title">Ce que Foébé<br/><em>n'est pas</em></h2>
<p class="section-body">Foébé pose un cadre clair : ne pas diagnostiquer, ne pas promettre une transformation instantanée, ne pas créer de dépendance. La méthode sert à comprendre, structurer et rendre les repères utilisables.</p>
</div>
<div class="posture-grid reveal reveal-delay-1">
<div class="posture-card">
<span class="posture-tag">Pas de la thérapie</span>
<p class="posture-not"><strong>Ce n'est pas :</strong> un suivi thérapeutique, un traitement, un diagnostic clinique.</p>
<p class="posture-is"><em>Mais, un espace d'observation structurée pour des personnes fonctionnelles.</em></p>
</div>
<div class="posture-card">
<span class="posture-tag">Pas du coaching</span>
<p class="posture-not"><strong>Ce n'est pas :</strong> des objectifs à atteindre, une motivation à entretenir, un accompagnement vers la performance.</p>
<p class="posture-is"><em> Mais, une lecture de ce qui se passe. Comprendre d'abord, agir ensuite.</em></p>
</div>
<div class="posture-card">
<span class="posture-tag">Pas du wellness générique</span>
<p class="posture-not"><strong>Ce n'est pas :</strong> des conseils universels, des routines miracles, des injonctions à prendre soin de soi.</p>
<p class="posture-is"><em> Mais, une grille de lecture personnalisée, fondée sur des modèles validés.</em></p>
</div>
<div class="posture-card">
<span class="posture-tag">Pas un test de personnalité</span>
<p class="posture-not"><strong>Ce n'est pas :</strong> une étiquette, une case, un résultat figé.</p>
<p class="posture-is"><em> Mais, une lecture située du fonctionnement, ici et maintenant.</em></p>
</div>
</div>
</div>
</section><section class="section bg3">
<div class="section-inner">
<div class="reveal">
<span class="section-eyebrow">Ce que la méthode produit</span>
<h2 class="section-title">Pas un score.<br/><em>Une lecture.</em></h2>
</div>
<div class="reveal reveal-delay-1 method-proof-box">
<p class="method-proof-quote">
          "Les questionnaires Foébé ne sont pas des instruments de diagnostic clinique. Ce sont des grilles de lecture non pathologisantes, conçues pour des personnes fonctionnelles souhaitant mieux comprendre leur propre rapport au self-care."
        </p>
<p class="method-proof-source">La fondatrice · Docteure en psychologie et ergonome</p>
</div>
</div>
</section><section class="conclusion-section">
<div class="conclusion-inner">
<p class="conclusion-quote reveal">L'objectif n'est pas de tout résoudre d'un coup, mais de savoir <em>où regarder en premier.</em></p>
<div class="reveal reveal-delay-1 conclusion-actions"><a class="btn-cta" href="/echelle-foebe/">Faire l'Échelle Foébé</a><a class="btn-outline" href="/zones/">Explorer les 7 zones →</a><a class="btn-outline" href="/pratiquer/">Voir tous les outils →</a></div>
</div>
</section>
<GuidedFaq
  id="methode-faq"
  compact
  title="Ce que la méthode permet — et ce qu’elle ne prétend pas faire."
  items={methodeFaq}
/>
<GuidedNextSteps
  id="methode-next"
  title="Relie la méthode à une prochaine étape concrète."
  links={[
    { href: '/a-propos/', kicker: 'La fondatrice', label: 'Voir qui tient le cadre', description: 'Découvrir le parcours en psychologie, ergonomie et santé au travail.' },
    { href: '/zones/', kicker: 'Le modèle', label: 'Explorer les 7 zones', description: 'Voir comment le corps, le mental, les émotions et les autres dimensions se répondent.' },
    { href: '/faq/', kicker: 'Le projet', label: 'Lire les questions fréquentes', description: 'Le cadre non clinique, les ressources gratuites et les futures ouvertures.' },
  ]}
/>
</main><div aria-hidden="true" class="chip-modal-backdrop" id="heroChipModal">
<section aria-labelledby="chipModalTitle" aria-modal="true" class="chip-modal" role="dialog">
<button aria-label="Fermer la définition" class="chip-modal-close" type="button">×</button>
<h2 class="chip-modal-title" id="chipModalTitle">Détail du repère Foébé</h2>
<p class="chip-modal-text" id="chipModalText"></p>
</section>
</div>


<script is:inline src="/scripts/pages/methode.js"></script>
</BaseLayout>
