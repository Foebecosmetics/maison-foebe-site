---
const { zone } = Astro.props;
const jsonLd = JSON.stringify(zone.jsonLd ?? {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: zone.title,
  description: zone.description,
  url: zone.canonical
});
---
<title>{zone.title}</title>
<meta name="description" content={zone.description} />
<link rel="canonical" href={zone.canonical} />
<meta name="robots" content="index, follow" />
<meta property="og:type" content="website" />
<meta property="og:title" content={zone.ogTitle} />
<meta property="og:description" content={zone.ogDescription} />
<meta property="og:url" content={zone.canonical} />
{zone.ogImage && <meta property="og:image" content={zone.ogImage} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={zone.twitterTitle || zone.ogTitle} />
<meta name="twitter:description" content={zone.twitterDescription || zone.ogDescription} />
{zone.ogImage && <meta name="twitter:image" content={zone.ogImage} />}
<script type="application/ld+json" set:html={jsonLd}></script>
