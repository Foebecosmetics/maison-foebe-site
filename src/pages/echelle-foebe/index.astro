const REQUIRED_DEMO_FIELDS = ['genre','age','statut','pays','enfants','professionnel_sante'];

function getMissingDemoFields(){
  return REQUIRED_DEMO_FIELDS.filter(field => !String(demoData[field] || '').trim());
}

function updateConsentCompletionState(){
  const missing = getMissingDemoFields();
  const completed = REQUIRED_DEMO_FIELDS.length - missing.length;
  const button = document.getElementById('btnConsentYes');
  const status = document.getElementById('demoCompletionStatus');
  const count = document.getElementById('demoCompletionCount');
  const error = document.getElementById('demoValidationError');

  if(count) count.textContent = `${completed} / ${REQUIRED_DEMO_FIELDS.length}`;
  if(status){
    status.classList.toggle('is-complete', missing.length === 0);
    const text = status.querySelector('span');
    if(text){
      text.textContent = missing.length === 0
        ? 'Les informations nécessaires sont complètes. Tu peux valider ta contribution.'
        : `Il reste ${missing.length} réponse${missing.length > 1 ? 's' : ''} à renseigner pour contribuer.`;
    }
  }
  if(button){
    button.disabled = missing.length !== 0;
    button.setAttribute('aria-disabled', missing.length !== 0 ? 'true' : 'false');
  }
  if(error && missing.length === 0){
    error.classList.remove('visible');
    error.textContent = '';
  }

  document.querySelectorAll('.demo-q[data-required-field]').forEach(block => {
    const field = block.getAttribute('data-required-field');
    block.setAttribute('aria-invalid', missing.includes(field) ? 'true' : 'false');
  });
  return missing;
}

function validateConsentForm(){
  const missing = getMissingDemoFields();
  if(missing.length === 0) return true;

  const labels = {
    genre:'le genre', age:"la tranche d’âge", statut:'le statut professionnel',
    pays:'le pays ou la région', enfants:'la situation familiale',
    professionnel_sante:'la question sur le recours à un professionnel'
  };
  const error = document.getElementById('demoValidationError');
  if(error){
    error.textContent = `Pour contribuer, complète encore : ${missing.map(field => labels[field]).join(', ')}.`;
    error.classList.add('visible');
  }

  document.querySelectorAll('.demo-q[data-required-field]').forEach(block => {
    const field = block.getAttribute('data-required-field');
    block.classList.toggle('is-missing', missing.includes(field));
    block.setAttribute('aria-invalid', missing.includes(field) ? 'true' : 'false');
  });

  const first = document.querySelector(`.demo-q[data-required-field="${missing[0]}"]`);
  if(first){
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    first.scrollIntoView({behavior: reduce ? 'auto' : 'smooth', block:'center'});
    window.setTimeout(() => first.querySelector('.demo-btn')?.focus(), reduce ? 0 : 250);
  }
  return false;
}

function showConsentScreen(){
  // Si déjà contribué, montrer le message de retour et cacher le promo évolution
  if(hasContributed()){
    document.getElementById('alreadyContributedMsg').hidden = false;
    document.getElementById('evolutionPromo').hidden = true;
    prefillConsentForm();
  } else {
    document.getElementById('alreadyContributedMsg').hidden = true;
    document.getElementById('evolutionPromo').hidden = false;
  }
  updateConsentCompletionState();
  showScreen('screenConsent');
}

function selectDemo(field, value, btn){
  demoData[field] = value;
  btn.closest('.demo-options').querySelectorAll('.demo-btn').forEach(b => {
    b.classList.remove('selected');
    b.setAttribute('aria-checked','false');
  });
  btn.classList.add('selected');
  btn.setAttribute('aria-checked','true');
  const block = btn.closest('.demo-q');
  if(block) block.classList.remove('is-missing');
  updateConsentCompletionState();
}

function prefillConsentForm(){
  const saved = lsGetJSON('foebe_demo');
  if(!saved) return;
  Object.keys(saved).forEach(k => { if(demoData.hasOwnProperty(k)) demoData[k] = saved[k]; });
  const mapping = {
    genre:'demoGenre', age:'demoAge', statut:'demoStatut',
    pays:'demoPays', enfants:'demoEnfants', professionnel_sante:'demoPro'
  };
  Object.entries(mapping).forEach(([field, containerId]) => {
    const val = demoData[field];
    if(!val) return;
    const container = document.getElementById(containerId);
    if(!container) return;
    container.querySelectorAll('.demo-btn').forEach(btn => {
      if(btn.textContent.trim() === val || btn.getAttribute('onclick')?.includes(`'${val}'`)){
        btn.classList.add('selected');
        btn.setAttribute('aria-checked','true');
      }
    });
  });
  updateConsentCompletionState();
}

function buildResearchPayload(axeScores, total, profileLabel, verbatim = null, useLegacySchema = false){
  const savedDemo = lsGetJSON('foebe_demo') || demoData || {};
  const base = {
    user_id: getUserId(),
    genre: savedDemo.genre || null,
    age: savedDemo.age || null,
    statut: savedDemo.statut || null,
    pays: savedDemo.pays || null,
    enfants: savedDemo.enfants || null,
    professionnel_sante: savedDemo.professionnel_sante || null,
    profil: profileLabel,
    score_global: total,
    score_corps: axeScores[0],
    score_repos: axeScores[1],
    score_emotions: axeScores[2],
    score_mental: axeScores[3],
    score_relations: axeScores[5],
    score_sens: axeScores[6],
    verbatim: verbatim || null,
  };

  if(useLegacySchema){
    const marker = '[Échelle Foébé v2 — axe 7 stocké dans score_performance = Environnement]';
    base.score_performance = axeScores[4];
    base.verbatim = verbatim ? `${marker} ${verbatim}` : marker;
  } else {
    base.score_environnement = axeScores[4];
    base.questionnaire_version = QUESTIONNAIRE_VERSION_LABEL;
  }
  return base;
}

async function postResearchPayload(axeScores, total, profileLabel, verbatim = null){
  const endpoint = `${SUPABASE_URL}/rest/v1/reponses_test`;
  const headers = {
    'Content-Type':'application/json',
    'apikey': SUPABASE_KEY,
    'Authorization': `Bearer ${SUPABASE_KEY}`,
    'Prefer':'return=minimal'
  };

  try{
    const response = await fetch(endpoint, {
      method:'POST',
      headers,
      keepalive:true,
      body: JSON.stringify(buildResearchPayload(axeScores, total, profileLabel, verbatim, false))
    });
    if(response.ok) return true;
  }catch(e){}

  // Compatibilité avec la table historique si les nouvelles colonnes Supabase
  // n'ont pas encore été créées. L'expérience utilisateur reste non bloquante.
  try{
    const legacyResponse = await fetch(endpoint, {
      method:'POST',
      headers,
      keepalive:true,
      body: JSON.stringify(buildResearchPayload(axeScores, total, profileLabel, verbatim, true))
    });
    return legacyResponse.ok;
  }catch(e){
    return false;
  }
}

async function submitConsent(){
  // La contribution n'est valide que lorsque les 6 réponses obligatoires sont complètes.
  if(consentSubmitting || !validateConsentForm()) return;
  consentSubmitting = true;
  const consentButton = document.getElementById('btnConsentYes');
  if(consentButton){
    consentButton.disabled = true;
    consentButton.setAttribute('aria-disabled','true');
  }

  // 1. Sauvegarder le consentement localement
  lsSet('foebe_contributed', 'true');
  lsSetJSON('foebe_demo', demoData);

  // 2. Calculer les scores
  const { axeScores, total } = computeScores();
  const profile = profiles.find(p => total >= p.range[0] && total <= p.range[1]) || profiles[3];
  const profileLabels = ['Self-care ancré','Self-care en construction','Self-care fragmenté','Self-care en veille'];
  const profileLabel = profileLabels[profiles.indexOf(profile)] || 'Inconnu';

  // 3. Sauvegarder ce passage dans l'historique local
  savePassage(axeScores, total, profileLabel);

  // 4. Envoyer à Supabase en arrière-plan (non bloquant)
  const verbatim = document.getElementById('demoVerbatim')?.value?.trim() || null;
  postResearchPayload(axeScores, total, profileLabel, verbatim);

  // 5. Afficher les résultats
  renderResults();
  showScreen('screenResults');
  setTimeout(() => animateBars(), 100);
}

function skipConsent(){
  // La personne refuse — on affiche les résultats sans sauvegarder
  renderResults(true); // true = pas de sauvegarde historique
  showScreen('screenResults');
  setTimeout(() => animateBars(), 100);
}

// ══════════════════════════════════════════════════════
// AFFICHAGE RÉSULTATS
// ══════════════════════════════════════════════════════
function renderResults(skipHistory = false){
  const { axeScores, axeItemScores, total } = computeScores();
  const historyEnabled = hasContributed() && !skipHistory;
  const profile = profiles.find(p => total >= p.range[0] && total <= p.range[1]) || profiles[3];
  const profileLabels = ['Self-care ancré','Self-care en construction','Self-care fragmenté','Self-care en veille'];
  const profileLabel = profileLabels[profiles.indexOf(profile)] || 'Inconnu';

  // Historique, comparaison et envoi réservés aux personnes ayant consenti.
  if(historyEnabled){
    const history = getHistory();
    // Éviter les doublons si on appelle renderResults plusieurs fois
    const lastEntry = history[history.length - 1];
    const now = Date.now();
    const lastDate = lastEntry ? new Date(lastEntry.date).getTime() : 0;
    if(now - lastDate > 10000){ // plus de 10 secondes d'écart = nouveau passage
      savePassage(axeScores, total, profileLabel);
      // Envoyer aussi à Supabase pour les passages suivants
      sendToSupabase(axeScores, total, profileLabel);
    }
  }

  // Carte profil
  document.getElementById('gsTitle').innerHTML = profile.title;
  document.getElementById('gsDesc').textContent = profile.desc;

  // Sauvegarder pour animateBars
  window._axeScores = axeScores;

  // Les courbes et comparaisons ne sont calculées qu'après consentement.
  const allHistory = historyEnabled ? getHistory() : [];
  const history = historyEnabled ? getComparableHistory(allHistory) : [];
  const versionNotice = document.getElementById('historyVersionNotice');
  versionNotice.hidden = !(historyEnabled && hasLegacyHistory(allHistory));

  if(historyEnabled && history.length >= 2){
    document.getElementById('evolutionSection').hidden = false;
    renderEvolutionChart(history);
  } else {
    document.getElementById('evolutionSection').hidden = true;
  }

  // Barres par axe
  const axesList = document.getElementById('axesList');
  axesList.innerHTML = '';
  const prevScores = historyEnabled && history.length >= 2 ? history[history.length - 2].scores : null;

  axeScores.forEach((score, i) => {
    const pct = Math.round((score/15)*100);
    const cls = pct >= 75 ? 'fort' : pct >= 50 ? 'moyen' : pct >= 30 ? 'fragile' : 'critique';
    const labels = {fort:'Solide', moyen:'À nourrir', fragile:'Fragile', critique:'Priorité'};
    const insightIdx = pct >= 75 ? 0 : pct >= 50 ? 1 : pct >= 30 ? 2 : 3;

    // Badge delta
    let deltaHtml = '';
    if(prevScores){
      const diff = score - prevScores[i];
      if(Math.abs(diff) <= 1){
        deltaHtml = `<span class="axe-delta same" title="Écart de ${diff} point : globalement stable" aria-label="Globalement stable">stable</span>`;
      } else if(diff > 1){
        deltaHtml = `<span class="axe-delta up" title="Évolution à observer : plus ${diff} points" aria-label="Évolution à observer : plus ${diff} points">+${diff}</span>`;
      } else {
        deltaHtml = `<span class="axe-delta down" title="Évolution à observer : ${diff} points" aria-label="Évolution à observer : ${diff} points">${diff}</span>`;
      }
    }

    axesList.innerHTML += `
      <div class="axe-row">
        <div class="axe-header">
          <span class="axe-name">${axes[i].name}${deltaHtml}</span>
          <span class="axe-tag ${cls}">${labels[cls]}</span>
        </div>
        <div class="axe-bar-bg">
          <div class="axe-bar-fill ${cls}" id="axebar${i}" style="--delay:${0.2+i*0.12}s"></div>
        </div>
        <p class="axe-insight">${axeInsights[i][insightIdx]}</p>
      </div>`;
  });

  // Une seule zone prioritaire est affichée. Le calcul départage d'abord les
  // totaux et le détail des réponses. Une égalité parfaite a déjà été résolue
  // par la micro-question de vécu, jamais par hasard ni par ordre fixe.
  const priorityResolution = resolvePriority(axeScores, axeItemScores);
  const validPriority = Number.isInteger(selectedPriorityIndex) &&
    selectedPriorityIndex >= 0 && selectedPriorityIndex < axes.length &&
    priorityResolution.primaryIndexes.includes(selectedPriorityIndex);
  const priorityIdx = validPriority
    ? selectedPriorityIndex
    : (priorityResolution.primaryIndexes.length === 1 ? priorityResolution.primaryIndexes[0] : null);

  const priorityActions = document.getElementById('priorityActions');
  const priorityTitle = document.getElementById('priorityTitle');
  const priorityText = document.getElementById('priorityText');
  const priorityLabel = document.getElementById('priorityLabel');

  priorityActions.innerHTML = '';
  priorityActions.classList.remove('is-multiple');

  if(priorityIdx === null){
    // Garde-fou : en cas d'appel direct imprévu, on ne fabrique jamais une
    // priorité arbitraire. On redemande le départage avant d'afficher le résultat.
    resolveSinglePriorityBeforeResults();
    return;
  }

  const priorityAxe = axes[priorityIdx];
  priorityLabel.textContent = 'Ton point de départ cette semaine';
  priorityTitle.textContent = priorityAxe.name;
  priorityText.textContent = priorityMessages[priorityIdx];
  priorityActions.innerHTML = `<a class="btn-priority" id="priorityBtn" href="${priorityAxe.page}">Explorer ${priorityAxe.zoneName} →</a>`;
}

function animateBars(){
  const axeScores = window._axeScores || [];
  setTimeout(() => {
    axeScores.forEach((score, i) => {
      const el = document.getElementById('axebar'+i);
      if(el) el.style.width = Math.round((score/15)*100) + '%';
    });
  }, 300);
}

// ══════════════════════════════════════════════════════
// GRAPHIQUE ÉVOLUTION
// ══════════════════════════════════════════════════════
function renderEvolutionChart(history){
  const chart = document.getElementById('evolutionComparison');
  const overview = document.getElementById('evolutionOverview');
  const subtitle = document.getElementById('evolutionSubtitle');
  const select = document.getElementById('evolutionMetric');
  if(!chart || !overview || !subtitle || !select || !Array.isArray(history) || history.length < 2) return;

  const ordered = history
    .filter(isComparableHistoryEntry)
    .slice()
    .sort((a,b) => new Date(a.date).getTime() - new Date(b.date).getTime())
    .slice(-12);
  if(ordered.length < 2) return;

  window._evolutionHistory = ordered;
  if(!select.dataset.ready){
    select.innerHTML = '<option value="global">Équilibre global</option>' + axes.map((axe,index) => `<option value="axe-${index}">${axe.name}</option>`).join('');
    select.value = 'global';
    select.addEventListener('change', () => drawEvolutionMetric(window._evolutionHistory || [], select.value));
    select.dataset.ready = 'true';
  }
  drawEvolutionMetric(ordered, select.value || 'global');
}

function drawEvolutionMetric(history, metricKey){
  const chart = document.getElementById('evolutionComparison');
  const overview = document.getElementById('evolutionOverview');
  const subtitle = document.getElementById('evolutionSubtitle');
  if(!chart || !overview || !subtitle || !Array.isArray(history) || history.length < 2) return;

  const isGlobal = metricKey === 'global';
  const axeIndex = isGlobal ? -1 : Math.max(0,Math.min(axes.length - 1,Number(String(metricKey).replace('axe-','')) || 0));
  const label = isGlobal ? 'Équilibre global' : axes[axeIndex].name;
  const minScore = isGlobal ? 21 : 3;
  const maxScore = isGlobal ? 105 : 15;
  const stableThreshold = isGlobal ? 3 : 1;
  const values = history.map(entry => {
    const total = Number.isFinite(Number(entry.total)) ? Number(entry.total) : entry.scores.reduce((sum,value) => sum + (Number(value) || 0),0);
    const value = isGlobal ? total : Number(entry.scores[axeIndex]);
    return {...entry,value:Math.max(minScore,Math.min(maxScore,value))};
  });

  const previous = values[values.length - 2];
  const latest = values[values.length - 1];
  const delta = latest.value - previous.value;
  const trend = delta > stableThreshold ? 'up' : delta < -stableThreshold ? 'down' : 'same';
  const trendText = trend === 'up' ? `Plus soutenu (+${delta})` : trend === 'down' ? `Moins soutenu (−${Math.abs(delta)})` : 'Repère stable';

  const formatMoment = (iso,withTime=false) => {
    const date = new Date(iso);
    const dateText = date.toLocaleDateString('fr-FR',{day:'numeric',month:'short'});
    return withTime ? `${dateText} · ${date.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'})}` : dateText;
  };
  const dayCounts = values.reduce((acc,entry) => {
    const key = new Date(entry.date).toISOString().slice(0,10);
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  },{});
  const labels = values.map(entry => {
    const key = new Date(entry.date).toISOString().slice(0,10);
    return formatMoment(entry.date,dayCounts[key] > 1);
  });

  subtitle.textContent = `${label} · ${values.length} passage${values.length>1?'s':''} daté${values.length>1?'s':''}${history.length > 12 ? ' (12 plus récents)' : ''}.`;
  overview.innerHTML = `<span class="${trend}">${trendText}</span> depuis le ${formatMoment(previous.date,true)}.`;

  const width = 680;
  const height = 300;
  const margin = {top:34,right:24,bottom:62,left:58};
  const plotW = width - margin.left - margin.right;
  const plotH = height - margin.top - margin.bottom;
  const x = index => margin.left + (values.length === 1 ? plotW/2 : index * (plotW/(values.length-1)));
  const y = value => margin.top + (maxScore-value) * (plotH/(maxScore-minScore));
  const points = values.map((entry,index) => ({...entry,x:x(index),y:y(entry.value),label:labels[index]}));
  const linePath = points.map((point,index) => `${index===0?'M':'L'} ${point.x.toFixed(1)} ${point.y.toFixed(1)}`).join(' ');
  const areaPath = `${linePath} L ${points[points.length-1].x.toFixed(1)} ${(margin.top+plotH).toFixed(1)} L ${points[0].x.toFixed(1)} ${(margin.top+plotH).toFixed(1)} Z`;
  const guideValues = [maxScore,Math.round((maxScore+minScore)/2),minScore];
  const maxDateLabels = window.innerWidth < 600 ? 4 : 6;
  const labelStep = Math.max(1,Math.ceil(values.length/maxDateLabels));

  const guides = guideValues.map((value,index) => `
    <line class="evolution-grid-line" x1="${margin.left}" y1="${y(value).toFixed(1)}" x2="${width-margin.right}" y2="${y(value).toFixed(1)}"></line>
    <text class="evolution-y-label" x="8" y="${(y(value)+4).toFixed(1)}">${index===0?'Plus soutenu':index===2?'Plus fragile':value}</text>`).join('');
  const pointSvg = points.map((point,index) => {
    const latestClass = index === points.length-1 ? ' latest' : '';
    const showDate = index === 0 || index === points.length-1 || index % labelStep === 0;
    const showValue = values.length <= 8 || index === points.length-1 || index === 0;
    return `
      <g>
        <title>${point.label} : ${point.value}/${maxScore}</title>
        <circle class="evolution-point${latestClass}" cx="${point.x.toFixed(1)}" cy="${point.y.toFixed(1)}" r="${index===points.length-1?7:5}"></circle>
        ${showValue ? `<text class="evolution-value" x="${point.x.toFixed(1)}" y="${(point.y-13).toFixed(1)}">${point.value}</text>` : ''}
        ${showDate ? `<text class="evolution-date${index===0?' first':index===points.length-1?' last':''}" x="${point.x.toFixed(1)}" y="${height-22}">${point.label}</text>` : ''}
      </g>`;
  }).join('');

  chart.setAttribute('aria-label',`${label} : évolution sur ${values.length} passages, du ${labels[0]} au ${labels[labels.length-1]}. Dernière variation : ${trendText.toLowerCase()}.`);
  chart.innerHTML = `
    <svg class="evolution-svg" viewBox="0 0 ${width} ${height}" role="presentation" aria-hidden="true">
      <defs>
        <linearGradient id="evolutionAreaGradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#C45279" stop-opacity=".22"></stop>
          <stop offset="100%" stop-color="#C45279" stop-opacity="0"></stop>
        </linearGradient>
      </defs>
      ${guides}
      <path class="evolution-area" d="${areaPath}"></path>
      <path class="evolution-line" d="${linePath}"></path>
      ${pointSvg}
    </svg>`;
}

// ══════════════════════════════════════════════════════
// SUPABASE — envoi pour les passages suivants
// ══════════════════════════════════════════════════════
function sendToSupabase(axeScores, total, profileLabel){
  postResearchPayload(axeScores, total, profileLabel, null);
}

