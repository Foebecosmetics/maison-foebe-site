function updateLikertFeedback(value){
  const feedback = document.getElementById('likertMobileFeedback');
  if(!feedback) return;
  feedback.querySelectorAll('[data-value]').forEach((item) => {
    item.classList.toggle('is-visible', Number(item.dataset.value) === Number(value));
