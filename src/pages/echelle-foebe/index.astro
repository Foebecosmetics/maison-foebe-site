function renderQ(idx){
  const q = questions[idx];
  document.getElementById('qCounter').textContent = `${idx+1} / ${questions.length}`;
  document.getElementById('qText').textContent = q.text;
  document.getElementById('qHint').textContent = q.hint;
  const likert = document.getElementById('likertBtns');
  likert.setAttribute('role', 'radiogroup');
  likert.setAttribute('aria-label', 'Réponse à la question en cours');
  likert.setAttribute('aria-describedby', 'likertScaleHelp likertMobileFeedback');
  likert.innerHTML = '';
  for(let v=1; v<=5; v++){
    const btn = document.createElement('button');
    btn.className = 'likert-btn' + (answers[idx] === v ? ' selected' : '');
    btn.textContent = v;
    btn.type = 'button';
    btn.setAttribute('aria-label', `${v} sur 5 — ${RESPONSE_LABELS[v-1]}`);
    btn.title = `${v} sur 5 — ${RESPONSE_LABELS[v-1]}`;
    btn.setAttribute('role', 'radio');
    btn.setAttribute('aria-checked', answers[idx] === v ? 'true' : 'false');
    btn.addEventListener('pointerdown', event => {
      if(event.pointerType === 'mouse' && event.button !== 0) return;
      document.querySelectorAll('.likert-btn').forEach((item,i) => {
        item.classList.toggle('is-pressing', i+1 === v);
      });
    });
    btn.addEventListener('pointercancel', () => {
      document.querySelectorAll('.likert-btn').forEach(item => item.classList.remove('is-pressing'));
    });
    btn.onclick = () => selectAnswer(idx, v);
    likert.appendChild(btn);
  }
  updateLikertFeedback(answers[idx] || null);
  const backButton = document.getElementById('btnBack');
  const canGoBack = idx > 0;
  backButton.setAttribute('aria-hidden', canGoBack ? 'false' : 'true');
  backButton.disabled = !canGoBack;
  backButton.tabIndex = canGoBack ? 0 : -1;
  updateDots(idx);
  resetScreenViewport();
}

function selectAnswer(idx, value){
  selectedPriorityIndex = null;
  pendingPriorityCandidates = [];
  answers[idx] = value;
  document.querySelectorAll('.likert-btn').forEach((btn,i) => {
    btn.classList.remove('is-pressing');
    btn.classList.toggle('selected', i+1 === value);
    btn.setAttribute('aria-checked', i+1 === value ? 'true' : 'false');
  });
  updateLikertFeedback(value);
  const phoneLayout = window.matchMedia && window.matchMedia('(max-width:599px), (max-height:599px) and (orientation:landscape)').matches;
  clearAnswerAdvance();
  answerAdvanceTimer = window.setTimeout(() => {
    answerAdvanceTimer = null;
    if(current !== idx) return;
    if(idx < questions.length - 1){
      current = idx + 1;
      renderQ(current);
    } else {
      finishTest();
    }
  }, phoneLayout ? 520 : 220);
}

function goBack(){
  clearAnswerAdvance();
  if(current > 0){ current--; renderQ(current); }
}

function computeScores(){
  const axeScores = [0,0,0,0,0,0,0];
  const axeCount  = [0,0,0,0,0,0,0];
  const axeItemScores = [[],[],[],[],[],[],[]];
  let total = 0;
  questions.forEach((q,i) => {
    const raw = answers[i] || 3;
    const score = q.inv ? (6-raw) : raw;
    axeScores[q.axe] += score;
    axeCount[q.axe]++;
    axeItemScores[q.axe].push(score);
    total += score;
  });
  const normalized = axeScores.map((s,i) => Math.round((s/(axeCount[i]*5))*15));
  return { axeScores: normalized, axeItemScores, total };
}

function resolvePriority(axeScores, axeItemScores, previousScores = null){
  const minScore = Math.min(...axeScores);
  const initialCandidates = axeScores.reduce((acc, score, index) => {
    if(score === minScore) acc.push(index);
    return acc;
  }, []);

  if(initialCandidates.length <= 1){
    return { primaryIndexes: initialCandidates, allMinimumIndexes: initialCandidates, usedTieBreak: false };
  }

  // Départage uniquement à partir des réponses : davantage d'items très bas,
  // item le plus bas, puis éventuelle dégradation depuis le passage précédent.
  const ranked = initialCandidates.map(index => {
    const items = axeItemScores[index] || [];
    return {
      index,
      criticalCount: items.filter(value => value === 1).length,
      lowCount: items.filter(value => value <= 2).length,
      minimumItem: items.length ? Math.min(...items) : 5,
      decline: Array.isArray(previousScores) && Number.isFinite(previousScores[index])
        ? previousScores[index] - axeScores[index]
        : 0
    };
  });

  const bestCritical = Math.max(...ranked.map(item => item.criticalCount));
  let finalists = ranked.filter(item => item.criticalCount === bestCritical);
  const bestLow = Math.max(...finalists.map(item => item.lowCount));
  finalists = finalists.filter(item => item.lowCount === bestLow);
  const lowestItem = Math.min(...finalists.map(item => item.minimumItem));
  finalists = finalists.filter(item => item.minimumItem === lowestItem);
  const biggestDecline = Math.max(...finalists.map(item => item.decline));
  finalists = finalists.filter(item => item.decline === biggestDecline);

  return {
    primaryIndexes: finalists.map(item => item.index),
    allMinimumIndexes: initialCandidates,
    usedTieBreak: finalists.length < initialCandidates.length
  };
}

// ══════════════════════════════════════════════════════
// FIN DU TEST — décision du flow
// ══════════════════════════════════════════════════════
function finishTest(){
  const elapsed = startTime ? (Date.now() - startTime) / 1000 : 999;
  if(elapsed < MIN_TIME_SECONDS && !ignoreTooFast){
    showTooFastScreen(elapsed);
    return;
  }
  resolveSinglePriorityBeforeResults();
}

function resolveSinglePriorityBeforeResults(){
  const { axeScores, axeItemScores } = computeScores();
  const resolution = resolvePriority(axeScores, axeItemScores);
  const candidates = resolution.primaryIndexes;

  if(candidates.length === 1){
    selectedPriorityIndex = candidates[0];
    pendingPriorityCandidates = [];
    proceedAfterPriorityChoice();
    return;
  }

  // Si les réponses actuelles restent strictement indécidables, on ne montre
  // jamais les noms des zones. La personne choisit une scène concrète, toutes
  // les scènes étant formulées dans le même contexte de fin de journée.
  selectedPriorityIndex = null;
  pendingPriorityCandidates = [...candidates];
  const options = document.getElementById('tieBreakOptions');
  options.innerHTML = candidates.map(index =>
    `<button type="button" class="tie-break-btn" onclick="choosePriority(${index})">${tieBreakSituations[index]}</button>`
  ).join('');
  showScreen('screenTieBreak');
}

function choosePriority(index){
  if(!pendingPriorityCandidates.includes(index)) return;
  selectedPriorityIndex = index;
  pendingPriorityCandidates = [];
  proceedAfterPriorityChoice();
}

function proceedAfterPriorityChoice(){
  if(hasContributed()){
    renderResults();
    showScreen('screenResults');
    setTimeout(() => animateBars(), 100);
  } else {
    showConsentScreen();
  }
}

function continueToResults(){
  // Depuis l'écran "trop rapide" — on force et on reprend le flow normal
  ignoreTooFast = true;
  finishTest();
}

function reviewAnswers(){
  // Relire sans effacer les réponses déjà données.
  clearAnswerAdvance();
  ignoreTooFast = true;
  current = 0;
  showScreen('screenQuestion');
  buildDots();
  renderQ(0);
}

function resumeTest(){
  clearAnswerAdvance();
  ignoreTooFast = true;
  showScreen('screenQuestion');
  renderQ(current);
}

