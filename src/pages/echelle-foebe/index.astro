}

// ══════════════════════════════════════════════════════
// POPUP RESPIRATION
// ══════════════════════════════════════════════════════
let popupTimer = null, popupCountdownTimer = null, popupRunning = false;
const POPUP_CYCLES = 4;
const POPUP_PHASES = [
  { name:'Inspire', dur:5, ballPos:'top',    color:'#BB7E60' },
  { name:'Expire',  dur:5, ballPos:'bottom', color:'#4A7C59' },
];
let popupCycle = 0, popupPhaseIdx = 0;
const POPUP_TRACK_H = 180, POPUP_BALL_D = 48;

function popupSetBall(pos, duration){
  const ball = document.getElementById('popupBall');
  const topPx    = -POPUP_BALL_D/2;
  const bottomPx = POPUP_TRACK_H - POPUP_BALL_D/2;
  ball.style.transition = duration > 0 ? `top ${duration}s linear` : 'none';
  ball.style.top = (pos === 'top' ? topPx : bottomPx) + 'px';
}

function openBreathPopup(){
  if(popupRunning) return;
  const popup = document.getElementById('breathPopup');
  popup.style.display = 'flex';
  popup.style.visibility = 'visible';
  popup.style.opacity = '1';
  popup.setAttribute('aria-hidden','false');
  popupRunning = true;
  popupCycle = 0;
  popupPhaseIdx = 0;
  popupSetBall('bottom', 0);
  document.getElementById('popupPhase').style.opacity = '0';
  document.getElementById('popupCount').style.opacity = '0';
  document.getElementById('popupCycles').textContent = '';
  const cd = document.getElementById('popupCountdown');
  cd.style.opacity = '1';
  let n = 3;
  cd.textContent = n;
  window.requestAnimationFrame(() => document.getElementById('breathPopupClose')?.focus());
  popupCountdownTimer = window.setInterval(() => {
    n--;
    if(n > 0){ cd.textContent = n; }
    else{
      window.clearInterval(popupCountdownTimer);
      popupCountdownTimer = window.setTimeout(() => {
        popupCountdownTimer = null;
        if(!popupRunning) return;
        cd.style.opacity = '0';
        cd.textContent = '';
        runPopupPhase();
      }, 400);
    }
  }, 1000);
}

function runPopupPhase(){
  if(!popupRunning) return;
  if(popupCycle >= POPUP_CYCLES){ closeBreathPopup(); return; }
  const phase = POPUP_PHASES[popupPhaseIdx];
  const prevPhase = popupPhaseIdx > 0 ? POPUP_PHASES[popupPhaseIdx-1] : POPUP_PHASES[POPUP_PHASES.length-1];
  document.getElementById('popupBall').style.background = phase.color;
  document.getElementById('popupBall').style.boxShadow = `0 0 28px 8px ${phase.color}44`;
  if(prevPhase.ballPos !== phase.ballPos) popupSetBall(phase.ballPos, phase.dur);
  const pl = document.getElementById('popupPhase');
  pl.style.opacity = '0';
  setTimeout(() => { pl.textContent = phase.name; pl.style.opacity = '1'; }, 200);
  document.getElementById('popupCycles').textContent = `Cycle ${popupCycle + 1} sur ${POPUP_CYCLES}`;
  const cl = document.getElementById('popupCount');
  cl.style.opacity = '0.6';
  cl.textContent = phase.dur;
  const start = Date.now();
  function tick(){
    if(!popupRunning) return;
    const remaining = phase.dur - Math.floor((Date.now()-start)/1000);
    if(remaining > 0){
      cl.textContent = remaining;
      popupTimer = setTimeout(tick, 1000 - ((Date.now()-start)%1000));
    } else {
      cl.textContent = '';
      popupPhaseIdx++;
      if(popupPhaseIdx >= POPUP_PHASES.length){ popupPhaseIdx = 0; popupCycle++; }
      popupTimer = setTimeout(() => runPopupPhase(), 400);
    }
  }
  popupTimer = setTimeout(tick, 1000);
}

function closeBreathPopup(){
  if(!popupRunning && document.getElementById('breathPopup')?.style.display === 'none') return;
  popupRunning = false;
  if(popupTimer){ window.clearTimeout(popupTimer); popupTimer = null; }
  if(popupCountdownTimer){
    window.clearTimeout(popupCountdownTimer);
    window.clearInterval(popupCountdownTimer);
    popupCountdownTimer = null;
  }
  const popup = document.getElementById('breathPopup');
  popup.style.display = 'none';
  popup.setAttribute('aria-hidden','true');
  resumeTest();
}

document.addEventListener('keydown', event => {
  if(!popupRunning) return;
  if(event.key === 'Escape'){
    event.preventDefault();
    closeBreathPopup();
    return;
  }
  if(event.key === 'Tab'){
    event.preventDefault();
    document.getElementById('breathPopupClose')?.focus();
  }
});

</script>

<script id="foebeScrollProgressFallbackScript">
(function(){
  var root = document.documentElement;
  var bar = document.getElementById('foebeScrollProgressFallbackBar');
  if (!bar) return;

  var active = false;
  var ticking = false;

  function progressIsDisabled(){
    return !!(document.body && document.body.getAttribute('data-foebe-progress') === 'off');
  }

  function update(){
    if (!active || progressIsDisabled()) {
      ticking = false;
      return;
    }
    var doc = document.documentElement;
    var body = document.body || doc;
    var scrollTop = window.pageYOffset || doc.scrollTop || body.scrollTop || 0;
    var fullHeight = Math.max(
      doc.scrollHeight, body.scrollHeight,
      doc.offsetHeight, body.offsetHeight,
      doc.clientHeight
    );
    var max = Math.max(0, fullHeight - window.innerHeight);
    var progress = max > 0 ? Math.min(1, Math.max(0, scrollTop / max)) : 0;
    bar.style.transform = 'scaleX(' + progress + ')';
    ticking = false;
  }

  function requestUpdate(){
    if (!active || ticking) return;
    ticking = true;
    if (window.requestAnimationFrame) window.requestAnimationFrame(update);
    else window.setTimeout(update, 16);
  }

  function activate(){
    if (active || progressIsDisabled()) return;
    active = true;
    window.addEventListener('scroll', requestUpdate, { passive:true });
    window.addEventListener('resize', requestUpdate);
    window.addEventListener('load', requestUpdate);
    requestUpdate();
  }

  function deactivate(){
    if (!active) return;
    active = false;
    window.removeEventListener('scroll', requestUpdate);
    window.removeEventListener('resize', requestUpdate);
    window.removeEventListener('load', requestUpdate);
    bar.style.transform = 'scaleX(0)';
    ticking = false;
  }

  function syncWithShell(){
    if (root.classList.contains('foebe-shell-failed')) activate();
    else deactivate();
  }

  window.addEventListener('foebe:shell-failed', syncWithShell);
  window.addEventListener('foebe:shell-ready', syncWithShell);

  if ('MutationObserver' in window) {
    new MutationObserver(syncWithShell).observe(root, {
      attributes:true,
      attributeFilter:['class']
    });
  }

  syncWithShell();
})();
</script>
</BaseLayout>
