function prefersReducedMotion(){
  return !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);
}

function clearAnswerAdvance(){
  if(answerAdvanceTimer !== null){
    window.clearTimeout(answerAdvanceTimer);
    answerAdvanceTimer = null;
  }
}

function resetScreenViewport(){
  const root = document.documentElement;
  const body = document.body;
  const rootScrollBehavior = root.style.scrollBehavior;
  const bodyScrollBehavior = body.style.scrollBehavior;

  // Une navigation entre écrans ne doit jamais ressembler à un scroll de page.
  // On neutralise temporairement le scroll fluide, on replace le viewport avant
  // le prochain rendu, puis on restaure les styles existants.
  root.style.scrollBehavior = 'auto';
  body.style.scrollBehavior = 'auto';
  root.scrollTop = 0;
  body.scrollTop = 0;
  window.scrollTo(0, 0);

  window.requestAnimationFrame(() => {
    root.style.scrollBehavior = rootScrollBehavior;
    body.style.scrollBehavior = bodyScrollBehavior;
  });
}

function showScreen(id){
  const target = document.getElementById(id);
  if(!target) return;
  document.querySelectorAll('.screen').forEach(screen => {
    const active = screen === target;
    screen.classList.toggle('active', active);
    screen.setAttribute('aria-hidden', active ? 'false' : 'true');
  });
  resetScreenViewport();
  target.setAttribute('tabindex','-1');
  window.requestAnimationFrame(() => {
    try{ target.focus({preventScroll:true}); }catch(e){ target.focus(); }
  });
}

