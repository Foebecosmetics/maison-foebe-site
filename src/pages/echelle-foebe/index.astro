// HISTORIQUE LOCAL — tableau de passages
// Les anciennes entrées restent conservées, mais seules les entrées de même
// version sont comparées afin de ne pas mélanger deux questionnaires différents.
// ══════════════════════════════════════════════════════
function getHistory(){
  const history = lsGetJSON('foebe_history');
  return Array.isArray(history) ? history : [];
}
function isComparableHistoryEntry(entry){
  return !!(
    entry &&
    entry.version === QUESTIONNAIRE_VERSION &&
    Number.isFinite(Date.parse(entry.date)) &&
    Array.isArray(entry.scores) &&
    entry.scores.length === axes.length &&
    entry.scores.every(score => Number.isFinite(Number(score))) &&
    Number.isFinite(Number(entry.total))
  );
}
function getComparableHistory(history = getHistory()){
  return history.filter(isComparableHistoryEntry);
}
function hasLegacyHistory(history = getHistory()){
  return history.some(entry => !isComparableHistoryEntry(entry));
}
function savePassage(axeScores, total, profileLabel){
  const history = getHistory();
  history.push({
    version: QUESTIONNAIRE_VERSION,
    versionLabel: QUESTIONNAIRE_VERSION_LABEL,
    date: new Date().toISOString(),
    scores: [...axeScores],
    total: total,
    profile: profileLabel
  });
  lsSetJSON('foebe_history', history);
}
function hasContributed(){
  return lsGet('foebe_contributed') === 'true';
}

