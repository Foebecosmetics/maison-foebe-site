---
import GuidedNextSteps from '../../components/GuidedNextSteps.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/pages/a-propos.css';

const aboutNextLinks = [
  { href: '/methode/', kicker: 'Le cadre', label: 'Comprendre la méthode', description: 'Voir comment psychologie, ergonomie et self-care sont reliés.' },
  { href: '/faq/', kicker: 'Questions fréquentes', label: 'Vérifier ce qu’est Foébé', description: 'Le cadre, les limites, les ressources gratuites et la suite du projet.' },
  { href: '/#portes', kicker: 'Prochaines ouvertures', label: 'Être tenu·e informé·e', description: 'Laisser ton email pour recevoir les informations lorsque les accompagnements seront prêts.' },
];
---

<BaseLayout
  title="À propos de Maison Foébé · Psychologie et ergonomie"
  description="Découvrir la fondatrice de Maison Foébé, son doctorat en psychologie, son expertise en ergonomie et l’origine d’un self-care structuré."
  canonical="https://maisonfoebe.fr/a-propos/"
  ogTitle="À propos de Maison Foébé"
  ogDesc="Le parcours scientifique, l’expertise en santé au travail et l’intention derrière Maison Foébé."
  ogImage="https://maisonfoebe.fr/images/og-maison-foebe-self-care.jpg"

  ogImageAlt="Logo coloré de Maison Foébé sur fond clair"

  schemaType="ProfilePage"
  pageName="À propos de Maison Foébé et de sa fondatrice"
  pageAbout="Psychologie du travail, ergonomie, facteurs humains et santé au travail">
<nav aria-label="Navigation de secours Maison Foébé" class="fallback-nav" id="fallbackNav">
<a aria-label="Maison Foébé — accueil" class="fallback-logo" href="/"><span>F</span><span>o</span><span>é</span><span>b</span><span>é</span></a>
<div class="fallback-links">
<a href="/comprendre/">Comprendre</a>
<a href="/methode/">Méthode</a>
<a href="/echelle-foebe/">Échelle Foébé</a>
<a href="/zones/">7 zones</a>
<a href="/dictionnaire/">Dictionnaire</a>
</div>
</nav>
<div aria-hidden="true" class="foebe-scroll-progress foebe-scroll-progress--fallback">
<span class="foebe-scroll-progress__bar" id="foebeScrollProgressFallbackBar"></span>
</div>
<noscript>
<style>
    .foebe-scroll-progress--fallback{display:block!important}
  </style>
</noscript>
<main id="mainContent" tabindex="-1">
<section aria-labelledby="about-title" class="about-hero">
<div class="about-hero-grid">
<div class="hero-copy reveal">
<span class="hero-eyebrow">Qui tient le cadre</span>
<h1 class="hero-title" id="about-title">À propos de Maison Foébé.<br/><span class="foebe-warm">La recherche comme socle. Le vécu comme point de départ.</span></h1>
<span aria-hidden="true" class="hero-rule"></span>
<p class="hero-intro">Maison Foébé est un espace structuré de self-care, construit pour rendre lisible ce qui s’épuise chez des personnes qui continuent pourtant à fonctionner.</p>
<p class="hero-reassurance">Ici, la psychologie, l’ergonomie et les facteurs humains ne servent pas à réduire l’expérience : ils offrent un cadre pour mieux la comprendre.</p>
<div aria-label="Repères fondateurs" class="hero-proof">
<span>Psychologie</span><span>Ergonomie</span><span>Facteurs humains</span>
</div>
</div>
<figure aria-labelledby="orbit-caption" class="about-visual reveal reveal-delay-1">
<div aria-hidden="true" class="orbit-stage">
<div class="orbit-ring orbit-ring--outer"></div>
<div class="orbit-ring orbit-ring--middle"></div>
<div class="orbit-ring orbit-ring--inner"></div>
<div class="orbit-core"><strong>Foébé</strong></div>
<div class="orbit-node node-research"><strong>Recherche</strong><span>Observer</span></div>
<div class="orbit-node node-field"><strong>Terrain</strong><span>Structurer</span></div>
<div class="orbit-node node-lived"><strong>Vécu</strong><span>Restituer</span></div>
</div>
<figcaption id="orbit-caption">Une interface entre recherche, terrain et expérience vécue.</figcaption>
</figure>
</div>
</section>
<section aria-labelledby="founder-title" class="about-section about-section--soft">
<div class="section-inner">
<header class="section-heading reveal">
<span class="section-eyebrow">La fondatrice</span>
<h2 class="section-title" id="founder-title">Une expertise <span class="foebe-rose">ancrée dans la recherche.</span></h2>
</header>
<div class="founder-layout">
<aside class="identity-card reveal reveal-delay-1">
<div aria-label="Maison Foébé" class="identity-brand-orbit">
<span aria-hidden="true" class="identity-brand-ring identity-brand-ring--outer"></span>
<span aria-hidden="true" class="identity-brand-ring identity-brand-ring--inner"></span>
<span aria-hidden="true" class="identity-brand-logo">
<span>F</span><span>o</span><span>é</span><span>b</span><span>é</span>
</span>
</div>
<h3 class="identity-name">Docteure en psychologie<br/>et ergonome</h3>
<span class="identity-role">Fondatrice · Maison Foébé</span>
<p class="identity-copy">Un parcours en psychologie du travail et en ergonomie, centré sur la compréhension fine du fonctionnement humain, de la charge mentale et de ce qui épuise avant que cela ne se voie.</p>
</aside>
<div class="detail-list reveal reveal-delay-2">
<article class="detail-row">
<span class="detail-label">Formation</span>
<p>Doctorat en <strong>psychologie et Facteurs Humains et Ingénierie des Systèmes d’Information (EFHISI)</strong>, avec une spécialisation en santé au travail. Une base pour lire la charge mentale, les ressources psychiques et les mécanismes qui usent sans toujours se voir.</p>
</article>
<article class="detail-row">
<span class="detail-label">Posture</span>
<p><strong>Observer, structurer, restituer.</strong> Foébé s’appuie sur la psychologie, l’analyse de données, le transfert de connaissances et la vulgarisation rigoureuse pour rendre les fonctionnements complexes lisibles sans les appauvrir.</p>
</article>
<article class="detail-row">
<span class="detail-label">Intention</span>
<p>Créer une interface entre la recherche, le terrain et l’expérience vécue. Traduire des concepts psychologiques, ergonomiques et liés au stress en repères concrets pour comprendre ce qui s’épuise avant que cela ne devienne visible.</p>
</article>
</div>
</div>
</div>
</section>
<section aria-labelledby="research-title" class="about-section">
<div class="section-inner">
<header class="section-heading reveal">
<span class="section-eyebrow">Publications</span>
<h2 class="section-title" id="research-title">Un socle scientifique, <span class="foebe-red">de la psychologie aux facteurs humains.</span></h2>
<p class="section-copy">Les travaux fondateurs de Foébé portent sur la santé au travail, les conduites dopantes, les conditions de travail, la performance et les mécanismes qui transforment une contrainte en épuisement silencieux.</p>
</header>
<div class="research-shell reveal reveal-delay-1">
<article class="research-row">
<span class="research-type">Thèse de doctorat</span>
<div>
<h3 class="research-title">Quand l’automédication devient une conduite dopante chez les travailleurs</h3>
<p class="research-desc">Un travail doctoral sur les mécanismes par lesquels une pratique de soin ordinaire peut devenir une conduite de performance dans le contexte du travail.</p>
</div>
<a class="research-link" href="https://theses.hal.science/tel-02860264" rel="noopener noreferrer" target="_blank">Lire sur HAL →</a>
</article>
<article class="research-row research-row--rose">
<span class="research-type">Communication scientifique</span>
<div>
<h3 class="research-title">Working conditions and self-medication</h3>
<p class="research-desc">Une communication internationale prolongeant les résultats doctoraux autour des conditions de travail et de la recherche de performance.</p>
</div>
<a class="research-link" href="https://inpact-psychologyconference.org/wp-content/uploads/2021/04/1_P_142.pdf" rel="noopener noreferrer" target="_blank">Consulter →</a>
</article>
<article class="research-row research-row--red">
<span class="research-type">Publications</span>
<div>
<h3 class="research-title">Psychologie du travail, santé au travail et conduite dopante</h3>
<p class="research-desc">Publications issues des travaux doctoraux autour du lien entre travail, automédication, adaptation et épuisement silencieux.</p>
<p class="research-note">Revue PTO · chapitre d’ouvrage L’Harmattan · revue AFNOR. Références complètes et liens à venir.</p>
</div>
</article>
</div>
</div>
</section>
<section aria-labelledby="why-title" class="about-section about-section--deep">
<div class="why-panel reveal">
<span class="section-eyebrow">Ce qui manquait</span>
<h2 class="why-quote" id="why-title">Un espace entre <span class="foebe-warm">recherche et vécu</span>, capable de rendre les mécanismes lisibles sans les simplifier.</h2>
<p class="why-copy">Foébé est née d’un manque : beaucoup de personnes fonctionnent encore, mais ne savent plus lire les limites de leur propre self-care. Il ne manquait pas seulement des conseils, mais un cadre clair pour comprendre ce qui se dérègle et retrouver des repères.</p>
<span aria-hidden="true" class="why-rule"></span>
</div>
</section>
<section aria-labelledby="audience-heading" class="about-section about-section--soft">
<div class="section-inner">
<header class="section-heading reveal">
<span class="section-eyebrow">Personnes concernées</span>
<h2 class="section-title" id="audience-heading">Un espace pour celles et ceux qui <span class="foebe-rose">tiennent encore debout.</span></h2>
<p class="section-copy">Des personnes qui fonctionnent encore, mais sentent que quelque chose s’érode : leurs ressources, leur énergie, leur clarté ou leur capacité à vraiment récupérer.</p>
</header>
<div class="audience-shell reveal reveal-delay-1">
<article class="audience-row">
<span class="audience-index">01</span>
<div><span class="audience-label">Elles avancent encore</span><h3 class="audience-title">Actives et autonomes</h3></div>
<p class="audience-copy">Mais quelque chose s’érode : l’énergie, la clarté, la capacité à récupérer vraiment.</p>
</article>
<article class="audience-row">
<span class="audience-index">02</span>
<div><span class="audience-label">Recherche de fond</span><h3 class="audience-title">Réflexives, exigeantes, lasses du générique</h3></div>
<p class="audience-copy">Elles ont déjà lu, essayé, investi. Elles ne cherchent pas des conseils de plus, mais une lecture précise de leur propre fonctionnement.</p>
</article>
<article class="audience-row">
<span class="audience-index">03</span>
<div><span class="audience-label">Comprendre en profondeur</span><h3 class="audience-title">Prêtes à aller plus loin</h3></div>
<p class="audience-copy">Elles consacrent déjà du temps, de l’attention ou un budget à leur bien-être. Foébé devient un investissement dans la compréhension de leur propre système.</p>
</article>
<article class="audience-row">
<span class="audience-index">04</span>
<div><span class="audience-label">Le cadre</span><h3 class="audience-title">Comprendre sans réduire</h3></div>
<p class="audience-copy">Foébé propose un cadre pour comprendre ce qui s’épuise avant que cela ne devienne visible.</p>
</article>
</div>
</div>
</section>
<section class="closing">
<div class="closing-inner">
<p class="closing-quote reveal">Foébé existe parce qu’il manquait un espace pour lire <span class="foebe-warm">ce qui s’épuise avant que cela ne se voie.</span></p>
<div class="closing-actions reveal reveal-delay-1">
<a class="btn-primary" href="/methode/">Comprendre la méthode</a>
<a class="btn-outline" href="/echelle-foebe/">Faire l’Échelle Foébé →</a>
</div>
</div>
</section>

<GuidedNextSteps
  id="about-next"
  title="Comprendre le cadre, puis choisir ta prochaine étape."
  intro="Tu peux approfondir la méthode, vérifier les questions fréquentes ou simplement être informé·e de la suite."
  links={aboutNextLinks}
/>
</main>


<script is:inline src="/scripts/pages/a-propos.js"></script>
</BaseLayout>
