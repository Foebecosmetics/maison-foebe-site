---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/pages/boussole.css';

---

<BaseLayout
  title="Sas de la Boussole · Se situer avant d'entrer — Maison Foébé"
  description="Un sas Maison Foébé pour te situer, choisir une piste d’attention et entrer dans la Boussole avec un premier repère de lecture."
  canonical="https://maisonfoebe.fr/boussole/"
  ogTitle="Sas de la Boussole · Se situer avant d'entrer — Maison Foébé"
  ogDesc="Deux gestes simples avant la Boussole : reconnaître comment tu arrives, puis choisir ce qui attire ton attention."
  ogImage="https://maisonfoebe.fr/images/og-boussole.png"

  ogImageAlt="Illustration nocturne de la Boussole Maison Foébé"
>
<main class="page" id="mainContent" tabindex="-1">

    <!-- HERO -->
    <section class="hero reveal" aria-labelledby="hero-title">
      <span class="hero-mark" aria-hidden="true">🧭</span>
      <span class="hero-eyebrow">Sas de la Boussole</span>
      <h1 id="hero-title" class="hero-title">Boussole Foébé : avant d'entrer, <em>commence par te situer.</em></h1>

      <p class="hero-sub">
  <strong><em>Le sas te permet de partir de ton état du moment.</em></strong><br>
  Tu choisis ce qui ressemble le plus à ce que tu vis, puis le mot qui attire ton attention. À partir de là, tu entres dans la Boussole avec un premier repère pour lire les scénarios.
</p>

      <div class="route-strip" aria-label="Déroulé du sas" role="list">
        <div class="route-step" role="listitem"><span class="route-num">01</span><strong>Ton point de départ</strong></div>
        <div class="route-step" role="listitem"><span class="route-num">02</span><strong>Ce qui t'appelle</strong></div>
        <div class="route-step" role="listitem"><span class="route-num">03</span><strong>Ton premier repère </strong></div>
      </div>
    </section>

    <!-- ÉTAPE 01 -->
    <section id="etape-01" class="section reveal" aria-labelledby="step1-title">
      <div class="section-header">
        <span class="section-num">01</span>
        <h2 id="step1-title" class="section-title">Dans quel état <em>arrives-tu ?</em></h2>
        <p class="section-intro">Choisis la carte qui ressemble le plus à ce que tu vis maintenant.</p>
      </div>

      <div class="state-grid" role="group" aria-label="Choisir ton état du moment">
        <button class="choice-card state-card" type="button" data-state="energie" aria-pressed="false">
          <span class="state-emoji">🪫</span>
          <span class="state-label">À plat</span>
          <span class="state-hint">Je n’ai plus beaucoup de marge.</span>
        </button>
        <button class="choice-card state-card" type="button" data-state="mental" aria-pressed="false">
          <span class="state-emoji">🌀</span>
          <span class="state-label">Tête pleine</span>
          <span class="state-hint">Trop d’éléments se mélangent.</span>
        </button>
        <button class="choice-card state-card" type="button" data-state="emotions" aria-pressed="false">
          <span class="state-emoji">😶</span>
          <span class="state-label">Coupé·e</span>
          <span class="state-hint">Je ne sais plus bien ce que je ressens.</span>
        </button>
        <button class="choice-card state-card" type="button" data-state="corps" aria-pressed="false">
          <span class="state-emoji">🔥</span>
          <span class="state-label">À bout</span>
          <span class="state-hint">Tout semble trop demandé.</span>
        </button>
        <button class="choice-card state-card" type="button" data-state="sens" aria-pressed="false">
          <span class="state-emoji">🌫️</span>
          <span class="state-label">Perdu·e</span>
          <span class="state-hint">Je ne sais plus bien où aller.</span>
        </button>
        <button class="choice-card state-card" type="button" data-state="ouverture" aria-pressed="false">
          <span class="state-emoji">🌱</span>
          <span class="state-label">Curieux·se</span>
          <span class="state-hint">Je suis disponible pour explorer.</span>
        </button>
      </div>

      <div id="stateMirror" class="feedback-box" hidden>
        <p class="kicker">D'où tu pars</p>
        <p id="stateTitle" class="feedback-title"></p>
        <p id="stateText" class="feedback-text"></p>
        <div class="actions">
          <button class="btn btn-primary" type="button" data-scroll-target="etape-02">Continuer</button>
        </div>
      </div>
    </section>

    <!-- ÉTAPE 02 -->
    <section id="etape-02" class="section reveal locked" aria-labelledby="step2-title">
      <div class="section-header">
        <span class="section-num">02</span>
        <h2 id="step2-title" class="section-title">Choisis un mot, <em>sans trop réfléchir.</em></h2>
        <p class="section-intro">Laisse venir celui qui attire ton attention, même si tu ne sais pas encore pourquoi.</p>
      </div>

      <p id="lockNote" class="lock-note">Commence par te situer à l’étape 01.</p>

      <div class="word-grid" role="group" aria-label="Choisir une piste d'attention">
        <button class="choice-card word-card" type="button" data-word="repos" aria-pressed="false">
          <span class="word-symbol" aria-hidden="true">😴</span>
          <span class="word-label">Repos</span>
        </button>
        <button class="choice-card word-card" type="button" data-word="signal" aria-pressed="false">
          <span class="word-symbol" aria-hidden="true">🔔</span>
          <span class="word-label">Signal</span>
        </button>
        <button class="choice-card word-card" type="button" data-word="clarte" aria-pressed="false">
          <span class="word-symbol" aria-hidden="true">🕯️</span>
          <span class="word-label">Clarté</span>
        </button>
        <button class="choice-card word-card" type="button" data-word="vague" aria-pressed="false">
          <span class="word-symbol" aria-hidden="true">🌊</span>
          <span class="word-label">Vague</span>
        </button>
        <button class="choice-card word-card" type="button" data-word="espace" aria-pressed="false">
          <span class="word-symbol" aria-hidden="true">🍃</span>
          <span class="word-label">Espace</span>
        </button>
        <button class="choice-card word-card" type="button" data-word="lien" aria-pressed="false">
          <span class="word-symbol" aria-hidden="true">🤝</span>
          <span class="word-label">Lien</span>
        </button>
        <button class="choice-card word-card" type="button" data-word="nord" aria-pressed="false">
          <span class="word-symbol" aria-hidden="true">🧭</span>
          <span class="word-label">Nord</span>
        </button>
      </div>

      <div id="wordResult" class="feedback-box" hidden>
        <p class="kicker">Ce que ça appelle</p>
        <p id="wordTitle" class="feedback-title"></p>
        <p id="wordText" class="feedback-text"></p>
        <div class="actions">
          <button class="btn btn-primary" type="button" data-scroll-target="etape-03">Voir ma première piste</button>
        </div>
      </div>
    </section>

    <!-- ÉTAPE 03 -->
    <section id="etape-03" class="section reveal locked" aria-labelledby="step3-title">
      <div class="section-header">
        <span class="section-num">03</span>
        <h2 id="step3-title" class="section-title"><em>Ton premier repère</em></h2>
      </div>

      <div id="synthesisEmpty" class="synthesis synthesis-dormant">
        <p class="synthesis-empty">Elle se dessine à partir de tes deux choix et t’aide à lire les scénarios de la Boussole avec un premier repère.</p>
      </div>

      <div id="synthesisBox" class="synthesis" hidden>
        <div class="synthesis-grid">
          <div class="synthesis-chip"><span>Tu arrives avec</span><strong id="synState"></strong></div>
          <div class="synthesis-chip"><span>Ce qui t'appelle</span><strong id="synWord"></strong></div>
        </div>
        <p id="synCopy" class="synthesis-copy"></p>
        <div class="question-box"><p id="synQuestion"></p></div>
        <div class="actions" style="margin-top:20px;">
          <a id="synZoneLink" class="btn btn-primary" href="#">Explorer la zone liée</a>
          <a class="btn btn-secondary" href="/boussole-scenarios/">Entrer dans la Boussole</a>
        </div>
      </div>
    </section>

  </main>

  

  
  
<script is:inline src="/scripts/pages/boussole.js"></script>
</BaseLayout>
