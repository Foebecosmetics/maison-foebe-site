<script is:inline>
(function(){
  var mount=document.getElementById('dictionaryCorpusMount');
  var button=document.getElementById('dictLoadButton');
  var status=document.getElementById('dictLoadStatus');
  var loading=null;

  function setStatus(message){ if(status) status.textContent=message || ''; }
  function loadDictionary(){
    if(loading) return loading;
    setStatus('Chargement du dictionnaire…');
    if(button) button.disabled=true;
    loading=fetch('/data/dictionnaire-corpus.html',{credentials:'same-origin'})
      .then(function(response){ if(!response.ok) throw new Error('HTTP '+response.status); return response.text(); })
      .then(function(markup){
        mount.innerHTML=markup;
        var script=document.createElement('script');
        script.src='/scripts/dictionnaire-app.js';
        script.defer=true;
        document.body.appendChild(script);
        return new Promise(function(resolve,reject){
          script.addEventListener('load',function(){
            document.body.classList.add('dict-corpus-loaded');
            setStatus('Dictionnaire chargé.');
            if(button) button.hidden=true;
            resolve();
          },{once:true});
          script.addEventListener('error',reject,{once:true});
        });
      })
      .catch(function(error){
        setStatus('Le chargement a échoué. Utilise l’un des six répertoires ci-dessus.');
        if(button) button.disabled=false;
        loading=null;
        throw error;
      });
    return loading;
  }

  window.foebeLoadDictionary=loadDictionary;
  if(button) button.addEventListener('click',loadDictionary);

  document.addEventListener('pointerdown',function(event){
    var target=event.target.closest('[data-dict-entry],[data-observatoire-action],.chooser-open,.chooser-select,.entry-chip[href^="#"]');
    if(!target || document.body.classList.contains('dict-corpus-loaded')) return;
    if(target.tagName==='SELECT') return loadDictionary();
    event.preventDefault();
    loadDictionary().then(function(){ target.click(); });
  },true);

  var search=document.getElementById('dict-search');
  if(search){
    search.addEventListener('focus',function(){ loadDictionary(); },{once:true});
  }
  if(location.hash && location.hash.length>1) loadDictionary();
})();
</script>
