---
import GuidedNextSteps from '../../components/GuidedNextSteps.astro';
import GuidedFaq from '../../components/GuidedFaq.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/pages/dictionnaire.css';

const dictionnaireFaq = [
  { question: 'Dois-je connaître le bon mot avant de chercher ?', answer: 'Non. Tu peux partir d’un signal, d’un geste ou d’un besoin. Le Dictionnaire est conçu pour t’orienter sans exiger le vocabulaire exact.' },
  { question: 'Les fiches donnent-elles un diagnostic ou une prescription ?', answer: 'Non. Elles proposent des définitions, des précautions et des premiers repères. Elles ne remplacent pas un avis médical, dermatologique, psychologique ou pharmaceutique.' },
  { question: 'Pourquoi réunir self-care, peau, cheveux et corps ?', answer: 'Parce que ces dimensions se croisent dans la vie quotidienne, tout en gardant des besoins différents. Le Dictionnaire les relie sans les confondre.' },
];
---

<BaseLayout
  title="Dictionnaire du self-care, skincare, haircare et bodycare · Foébé"
  description="Définitions et repères sur le self-care, la récupération, la charge mentale, la skincare, la haircare et le bodycare, sans surcharge ni diagnostic."
  canonical="https://maisonfoebe.fr/dictionnaire/"
  ogTitle="Dictionnaire Foébé · Self-care, peau, cheveux et corps"
  ogDesc="Chercher un mot, observer un signal ou choisir un premier geste doux dans 131 fiches et guides structurés."
  ogImage="https://maisonfoebe.fr/images/og-dictionnaire.png"

  ogImageAlt="Illustration géométrique du Dictionnaire Maison Foébé"

  schemaType="CollectionPage"
  pageName="Dictionnaire Foébé"
  pageAbout="Définitions, repères et premiers gestes de self-care, skincare, haircare et bodycare">


<header class="dict-hero" id="mainContent" tabindex="-1"><p class="dict-hero-eyebrow">Maison Foébé</p><h1>Dictionnaire Foébé</h1><p class="dict-hero-sub">Self-care · Skincare · Haircare · Bodycare</p><span class="dict-count">Chercher un mot · Observer un signal · Choisir un geste</span></header>
<section aria-label="Note Foébé" class="dict-note">
  <div class="dict-context-grid">
    <div class="dict-note-inner">
      <p class="dict-note-badge">Note Foébé</p>
      <p class="dict-note-title">Lire avec douceur, pas comme un diagnostic.</p>
      <p class="dict-note-copy">Ces fiches et guides ne posent pas de diagnostic et ne remplacent pas un avis médical, dermatologique ou psychologique. Elles servent à mieux définir certains termes, repérer un signal et choisir un premier geste doux.</p>
    </div>
    <div class="dict-note-safety" role="note" aria-label="À garder en tête">
      <span class="dict-note-safety-label">À garder en tête</span>
      <strong class="dict-note-safety-text">En cas de douleur, symptôme persistant, aggravation, lésion, grossesse, allaitement, traitement médical ou détresse importante : demande un avis professionnel.</strong>
    </div>
  </div>
</section>
<section aria-label="Recherche dans le dictionnaire" class="dict-search-zone" id="recherche-observatoire"><div class="search-bar"><span aria-hidden="true" class="search-icon"><svg fill="none" height="16" viewbox="0 0 16 16" width="16" xmlns="http://www.w3.org/2000/svg"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"></circle><line stroke="currentColor" stroke-linecap="round" stroke-width="1.5" x1="11" x2="14.5" y1="11" y2="14.5"></line></svg></span><input aria-label="Recherche dans le dictionnaire" autocomplete="off" id="dict-search" placeholder="Chercher un mot, un symptôme, un actif, un geste…" type="search"/><button aria-label="Effacer la recherche" class="search-clear" id="search-clear" type="button">Effacer</button></div><div aria-live="polite" class="search-results" id="search-results"></div></section>
<section aria-labelledby="entry-title" class="dict-entry-hub observatoire-simple-hub">
  <div class="entry-panel observatoire-simple-panel">
    <p class="entry-kicker">Par où entrer</p>
    <h2 class="entry-title" id="entry-title">Commence par une seule intention.</h2>
    <p class="entry-copy">Le dictionnaire Maison Foébé sert à réduire le bruit : tu peux chercher un mot, partir d’un signal que tu observes, ou ouvrir directement un premier geste doux.</p>
    <div class="entry-grid observatoire-three-doors" role="list">
      <button class="entry-card observatoire-door is-primary" data-observatoire-action="search" type="button">
        <p class="entry-num">01</p>
        <strong>Je cherche un mot</strong>
        <span>Tu sais déjà ce que tu veux comprendre : tape un terme, un actif, une zone, un signal ou un geste.</span>
        <em>Recherche directe</em>
      </button>
      <button class="entry-card observatoire-door" data-dict-entry="terr-signaux" type="button">
        <p class="entry-num">02</p>
        <strong>Je cherche par signal</strong>
        <span>Tu pars d’une sensation, d’un signe visible, d’une fatigue, d’une peau qui change ou d’un corps qui alerte.</span>
        <em>Observer</em>
      </button>
      <button class="entry-card observatoire-door" data-dict-entry="terr-gestes" type="button">
        <p class="entry-num">03</p>
        <strong>Je cherche par geste</strong>
        <span>Tu veux agir doucement maintenant : routine simple, soin, récupération, ancrage ou repère pratique.</span>
        <em>Agir sans surcharge</em>
      </button>
    </div>
    <div aria-label="Raccourcis utiles" class="entry-tools observatoire-shortcuts">
      <span class="entry-tools-label">Raccourcis</span>
      <a class="entry-chip" href="#tableau-selection-des-huiles-tableau-de-reference">Je veux choisir une huile</a>
      <a class="entry-chip" href="#guide-compatibilites-des-actifs-reperes-de-tolerance">Je veux éviter de mélanger les actifs</a>
      <a class="entry-chip" href="#fiche-dette-de-recuperation">Je veux récupérer vite</a>
      <a class="entry-chip" href="#guide-formats-express">Je veux un rituel court</a>
      <button class="entry-chip" data-dict-entry="terr-mode-emploi" type="button">Mode d’emploi</button>
      <button class="entry-chip" data-dict-entry="terr-guides" type="button">Guides experts</button>
      <button class="entry-chip" data-dict-entry="terr-tableaux" type="button">Tableaux</button>
    </div>
  </div>
</section>
<section aria-label="Navigation rapide du dictionnaire" class="dict-mobile-switch">
  <button type="button" data-observatoire-action="search">Recherche</button>
  <button type="button" data-dict-entry="terr-signaux">Signaux</button>
  <button type="button" data-dict-entry="terr-gestes">Gestes</button>
  <button type="button" data-dict-entry="terr-mode-emploi">Mode d’emploi</button>
  <button type="button" data-dict-entry="terr-skincare">Peau</button>
  <button type="button" data-dict-entry="terr-haircare">Cheveux</button>
  <button type="button" data-dict-entry="terr-bodycare">Corps</button>
  <button type="button" data-dict-entry="terr-self-care">Self-care</button>
  <button type="button" data-dict-entry="terr-guides">Guides</button>
  <button type="button" data-dict-entry="terr-tableaux">Tableaux</button>
</section>
<section aria-label="Choisir une fiche, un tableau ou un guide" class="chooser-zone">
