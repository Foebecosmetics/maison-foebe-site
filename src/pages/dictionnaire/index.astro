  <div class="chooser-head"><div><p class="entry-kicker">Observer</p><h2>Je cherche par signal</h2><p>Choisis le signe le plus proche de ce que tu remarques. Les fiches sont rangées par famille pour garder une lecture claire.</p></div><span>Signal → fiche</span></div>
  <div class="chooser-select-row"><label for="select-terr-signaux">Choisir un signal.</label><select class="chooser-select" id="select-terr-signaux"><option value="">Sélectionner…</option><optgroup label="Skincare — états & signaux cutanés"><option value="fiche-peau-reactive">Peau réactive</option><option value="fiche-peau-deshydratee">Peau déshydratée</option><option value="fiche-imperfections">Imperfections</option><option value="fiche-peau-acneique">Peau acnéique</option><option value="fiche-hyperpigmentation">Hyperpigmentation</option><option value="fiche-peau-atopique">Peau atopique</option></optgroup><optgroup label="Haircare — manifestations capillaires"><option value="fiche-frisottis">Frisottis</option><option value="fiche-fourches">Fourches</option><option value="fiche-casse">Casse</option><option value="fiche-noeuds">Nœuds</option><option value="fiche-cuir-chevelu-sec">Cuir chevelu sec</option></optgroup><optgroup label="Bodycare — zones & inconforts"><option value="fiche-peau-du-corps-seche">Peau du corps sèche</option><option value="fiche-peau-du-corps-sensible">Peau du corps sensible</option><option value="fiche-keratose-pilaire">Kératose pilaire</option><option value="fiche-zones-de-friction">Zones de friction</option></optgroup><optgroup label="Self-care — surcharge, émotions & récupération"><option value="fiche-charge-mentale">Charge mentale</option><option value="fiche-surcharge-cognitive">Surcharge cognitive</option><option value="fiche-fatigue-decisionnelle">Fatigue décisionnelle</option><option value="fiche-hyperfonctionnement">Hyperfonctionnement</option><option value="fiche-trop-plein-emotionnel">Trop-plein émotionnel</option><option value="fiche-culpabilite-de-repos">Culpabilité de repos</option><option value="fiche-dette-de-recuperation">Besoin de récupération</option><option value="fiche-recuperation-incomplete">Récupération incomplète</option><option value="fiche-corps-en-alerte">Corps en alerte</option></optgroup></select><button class="chooser-open" data-select="select-terr-signaux" type="button">Ouvrir</button></div>
  <button class="focus-btn first-fiche" data-first="fiche-dette-de-recuperation" type="button">Ouvrir un repère fréquent.</button>
</section>
<section class="chooser-panel observatoire-chooser-panel" data-territory="terr-gestes" id="chooser-terr-gestes">
  <div class="chooser-head"><div><p class="entry-kicker">Agir</p><h2>Je cherche par geste</h2><p>Choisis un premier geste doux. Les gestes sont rangés par famille pour ouvrir une action simple, sans afficher tout le dictionnaire au départ.</p></div><span>Geste → fiche</span></div>
  <div class="chooser-select-row"><label for="select-terr-gestes">Choisir un geste.</label><select class="chooser-select" id="select-terr-gestes"><option value="">Sélectionner…</option><optgroup label="Skincare — routine, actifs & SPF"><option value="fiche-introduire-un-actif">Introduire un actif</option><option value="fiche-spf-protection-solaire">SPF : protection solaire</option><option value="fiche-hydratation-cutanee">Hydratation cutanée</option><option value="fiche-exfoliation">Exfoliation visage</option><option value="guide-compatibilites-des-actifs-reperes-de-tolerance">Compatibilités des actifs</option><option value="guide-routines-par-besoin">Routines par besoin</option></optgroup><optgroup label="Haircare — gestes capillaires"><option value="fiche-hydratation-capillaire">Hydratation capillaire</option><option value="fiche-leave-in">Leave-in</option><option value="fiche-sceller">Sceller</option><option value="fiche-loc-lco">LOC / LCO</option><option value="fiche-clarification">Clarification</option><option value="fiche-proteines-capillaires">Protéines capillaires</option></optgroup><optgroup label="Bodycare — soin du corps"><option value="fiche-hydratation-du-corps">Hydratation du corps</option><option value="fiche-exfoliation-du-corps">Exfoliation du corps</option><option value="fiche-routine-corps-logique-de-base">Routine corps</option><option value="fiche-auto-massage-corporel">Auto-massage corporel</option><option value="fiche-soin-des-mains">Soin des mains</option><option value="fiche-soin-des-pieds">Soin des pieds</option></optgroup><optgroup label="Self-care — récupération & régulation"><option value="fiche-micro-recuperation">Micro-récupération</option><option value="fiche-regulation-emotionnelle">Régulation émotionnelle</option><option value="fiche-systeme-nerveux-parasympathique">Système nerveux parasympathique</option><option value="fiche-ancrage-sensoriel">Ancrage sensoriel</option><option value="fiche-microrituel">Microrituel</option><option value="guide-formats-express">Formats express</option></optgroup><optgroup label="Guides experts — protocoles & parcours"><option value="guide-guide-1-les-huiles-vegetales">Guide huiles végétales</option><option value="guide-guide-2-actifs-skincare-routine">Guide actifs skincare & routine</option><option value="guide-guide-3-cheveux-textures">Guide cheveux & textures</option><option value="guide-introduire-un-actif-protocole-progressif">Protocole : introduire un actif</option><option value="guide-actifs-selon-le-terrain-cutane">Actifs selon le terrain cutané</option></optgroup></select><button class="chooser-open" data-select="select-terr-gestes" type="button">Ouvrir</button></div>
  <button class="focus-btn first-fiche" data-first="guide-formats-express" type="button">Ouvrir les rituels express.</button>
</section>
