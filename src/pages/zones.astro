    <span class="cosmos-center" aria-hidden="true">F</span>
    <a class="cosmos-star star-mental" href="zone-mental.html"><span>Mental</span></a>
    <a class="cosmos-star star-corps" href="zone-corps.html"><span>Corps</span></a>
