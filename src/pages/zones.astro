  .star-energie::before      {animation-delay:3.5s;  animation-duration:13s}
  .star-emotions::before     {animation-delay:5.2s;  animation-duration:10s}
  .star-relations::before    {animation-delay:2.6s;  animation-duration:14s}
  .star-environnement::before{animation-delay:7.4s;  animation-duration:11.5s}
  .star-sens::before         {animation-delay:.5s;   animation-duration:16s}
}
.foebe-wave{
  width:min(680px,100%);
  height:52px;
  margin:clamp(28px,4vw,42px) auto 0;
  color:var(--warm);
  opacity:.78;
}
.foebe-wave svg{display:block;width:100%;height:100%}
.foebe-wave path{
  fill:none;
  stroke:currentColor;
  stroke-width:2;
  stroke-linecap:round;
  stroke-dasharray:10 12;
}
@keyframes waveFlow{from{stroke-dashoffset:0}to{stroke-dashoffset:-132}}
@media(prefers-reduced-motion:no-preference){.foebe-wave path{animation:waveFlow 9s linear infinite}}
