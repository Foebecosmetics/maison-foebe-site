---
import ZoneSEO from '../components/seo/ZoneSEO.astro';
import '../styles/shell-fallback.css';
import '../styles/zone-base.css';
import '../styles/zone-premium.css';
import '../styles/zone-waves.css';
import '../styles/zone-a11y.css';
const { zone } = Astro.props;
---
<!doctype html>
<html lang="fr" data-theme="night" style={zone.cssVars}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function(){
        try {
          var saved = localStorage.getItem('foebeTheme');
          if (saved === 'day' || saved === 'night') {
            document.documentElement.setAttribute('data-theme', saved);
            return;
          }
        } catch(e) {}
        var p = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
        document.documentElement.setAttribute('data-theme', p ? 'day' : 'night');
      })();
    </script>
    <script id="foebe-shell-fallback-guard" is:inline>
      (function(){
        var h = document.documentElement;
        h.classList.add('foebe-shell-loading');
        window.setTimeout(function(){
          if (!h.classList.contains('foebe-shell-ready')) {
            h.classList.add('foebe-shell-failed');
          }
        }, 2500);
      })();
    </script>
    <ZoneSEO zone={zone} />
  </head>
  <body>
    <slot />
    <script defer data-website-id="f25f1f6a-c967-4466-a744-e78fa7f4932f" src="https://cloud.umami.is/script.js"></script>
    <script defer src="/foebe-shell.js"></script>
  </body>
</html>
