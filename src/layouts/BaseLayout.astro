---
/**
 * BaseLayout.astro — socle SEO et technique commun de Maison Foébé.
 * Une seule source pour les canonicals, cartes sociales, données structurées,
 * polices, analytics et scripts partagés.
 */
import '../styles/base.css';
import '../styles/phase-b.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDesc?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDesc?: string;
  twitterImage?: string;
  robots?: string;
  schemaType?: 'WebPage' | 'CollectionPage' | 'AboutPage' | 'ProfilePage' | 'FAQPage';
  pageName?: string;
  pageAbout?: string;
  extraStructuredData?: Record<string, unknown> | Record<string, unknown>[];
  faqItems?: { question: string; answer: string }[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDesc,
  ogImage = 'https://maisonfoebe.fr/images/og-maison-foebe-self-care.jpg',
  ogImageAlt = 'Maison Foébé — le self-care comme compétence',
  ogType = 'website',
  twitterTitle,
  twitterDesc,
  twitterImage,
  robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  schemaType = 'WebPage',
  pageName,
  pageAbout,
  extraStructuredData,
  faqItems = [],
} = Astro.props;

const SITE_URL = 'https://maisonfoebe.fr';
const SITE_NAME = 'Maison Foébé';
const ORG_ID = `${SITE_URL}/#organization`;
const SITE_ID = `${SITE_URL}/#website`;
const PERSON_ID = `${SITE_URL}/a-propos/#fondatrice`;
const normalizedCanonical = canonical.endsWith('/') || canonical === `${SITE_URL}` ? canonical : `${canonical}/`;
const pathname = new URL(normalizedCanonical).pathname;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID?.trim() || 'f25f1f6a-c967-4466-a744-e78fa7f4932f';

const routeLabels: Record<string, string> = {
  '/': 'Accueil',
  '/comprendre/': 'Comprendre',
  '/methode/': 'La méthode Foébé',
  '/pratiquer/': 'Pratiquer',
  '/zones/': 'Les 7 zones',
  '/echelle-foebe/': 'Échelle Foébé',
  '/respiration/': 'Respiration guidée',
  '/boussole/': 'Boussole Foébé',
  '/boussole-scenarios/': 'Scénarios de la Boussole',
  '/lexique/': 'Lexique Foébé',
  '/dictionnaire/': 'Dictionnaire Foébé',
  '/dictionnaire/mode-emploi/': 'Mode d’emploi du Dictionnaire',
  '/dictionnaire/guides/': 'Guides experts',
  '/dictionnaire/skincare/': 'Skincare',
  '/dictionnaire/skincare/fondamentaux/': 'Fondamentaux et états de peau',
  '/dictionnaire/skincare/actifs-routines/': 'Repères, actifs et gestes skincare',
  '/dictionnaire/haircare/': 'Haircare',
  '/dictionnaire/bodycare/': 'Bodycare',
  '/dictionnaire/self-care/': 'Self-care',
  '/a-propos/': 'À propos',
  '/faq/': 'Questions fréquentes',
  '/mentions-legales/': 'Informations légales',
  '/zone-energie/': 'Zone Énergie',
  '/zone-corps/': 'Zone Corps',
  '/zone-mental/': 'Zone Mental',
  '/zone-emotions/': 'Zone Émotions',
  '/zone-environnement/': 'Zone Environnement',
  '/zone-relations/': 'Zone Relations',
  '/zone-sens/': 'Zone Sens',
};

function breadcrumbPaths(currentPath: string): string[] {
  if (currentPath === '/') return ['/'];
  if (currentPath.startsWith('/zone-')) return ['/', '/pratiquer/', '/zones/', currentPath];
  if (currentPath.startsWith('/dictionnaire/skincare/') && currentPath !== '/dictionnaire/skincare/') return ['/', '/dictionnaire/', '/dictionnaire/skincare/', currentPath];
  if (currentPath.startsWith('/dictionnaire/') && currentPath !== '/dictionnaire/') return ['/', '/dictionnaire/', currentPath];
  if (currentPath === '/boussole-scenarios/') return ['/', '/pratiquer/', '/boussole/', currentPath];
  if (['/zones/', '/echelle-foebe/', '/respiration/', '/boussole/'].includes(currentPath)) {
    return ['/', '/pratiquer/', currentPath];
  }
  return ['/', currentPath];
}

const crumbs = breadcrumbPaths(pathname)
  .filter((value, index, arr) => arr.indexOf(value) === index)
  .map((path, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: routeLabels[path] ?? pageName ?? title,
    item: `${SITE_URL}${path === '/' ? '/' : path}`,
  }));

const organization = {
  '@type': 'Organization',
  '@id': ORG_ID,
  name: SITE_NAME,
  url: `${SITE_URL}/`,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE_URL}/images/logo-foebe.png`,
    width: 500,
    height: 500,
  },
  founder: { '@id': PERSON_ID },
  sameAs: [
    'https://www.instagram.com/maisonfoebe/',
    'https://www.tiktok.com/@maisonfoebe',
    'https://fr.pinterest.com/maisonfoebe/',
  ],
};

const founder = {
  '@type': 'Person',
  '@id': PERSON_ID,
  name: 'Fondatrice de Maison Foébé',
  jobTitle: 'Docteure en psychologie et ergonome',
  description: 'Fondatrice de Maison Foébé, spécialisée en psychologie du travail, ergonomie, facteurs humains et santé au travail.',
  worksFor: { '@id': ORG_ID },
  url: `${SITE_URL}/a-propos/`,
};

const website = {
  '@type': 'WebSite',
  '@id': SITE_ID,
  url: `${SITE_URL}/`,
  name: SITE_NAME,
  description: 'Un espace structuré du self-care pour apprendre à se lire, se réguler et retrouver une capacité d’action.',
  inLanguage: 'fr-FR',
  publisher: { '@id': ORG_ID },
};

const breadcrumb = crumbs.length > 1 ? {
  '@type': 'BreadcrumbList',
  '@id': `${normalizedCanonical}#breadcrumb`,
  itemListElement: crumbs,
} : null;

const pageNode: Record<string, unknown> = {
  '@type': schemaType,
  '@id': `${normalizedCanonical}#webpage`,
  url: normalizedCanonical,
  name: pageName ?? ogTitle ?? title,
  headline: pageName ?? ogTitle ?? title,
  description,
  inLanguage: 'fr-FR',
  isPartOf: { '@id': SITE_ID },
  publisher: { '@id': ORG_ID },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImage,
    width: 1200,
    height: 630,
    caption: ogImageAlt,
    representativeOfPage: true,
  },
  image: ogImage,
};
if (breadcrumb) pageNode.breadcrumb = { '@id': `${normalizedCanonical}#breadcrumb` };
if (pageAbout) pageNode.about = pageAbout;
if (schemaType === 'ProfilePage') pageNode.mainEntity = { '@id': PERSON_ID };
if (schemaType === 'FAQPage' && faqItems.length) {
  pageNode.mainEntity = faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  }));
}

const extraNodes = Array.isArray(extraStructuredData)
  ? extraStructuredData
  : extraStructuredData
    ? [extraStructuredData]
    : [];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [organization, founder, website, ...(breadcrumb ? [breadcrumb] : []), pageNode, ...extraNodes],
};
---

<!DOCTYPE html>
<html data-theme="night" lang="fr">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width,initial-scale=1,viewport-fit=cover" name="viewport" />

  <script is:inline>
  (function(){
    try {
      var saved = localStorage.getItem('foebeTheme');
      if (saved === 'day' || saved === 'night') {
        document.documentElement.setAttribute('data-theme', saved);
        return;
      }
    } catch(e) {}
    var p = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
    document.documentElement.setAttribute('data-theme', p ? 'day' : 'night');
  })();
  </script>

  <script id="foebe-shell-fallback-guard" is:inline>
  (function () {
    var root = document.documentElement;
    root.classList.add('foebe-shell-loading');
    window.__foebeShellWatchdog = window.setTimeout(function () {
      if (!root.classList.contains('foebe-shell-ready')) {
        root.classList.remove('foebe-shell-loading');
        root.classList.add('foebe-shell-failed');
        try { window.dispatchEvent(new CustomEvent('foebe:shell-failed')); } catch (e) {}
      }
    }, 3000);
  })();
  </script>
  <script is:inline>document.documentElement.classList.add('js-ready');</script>

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <meta name="author" content="Maison Foébé" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="theme-color" content="#1b0d0a" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#f5efe8" media="(prefers-color-scheme: light)" />
  <link rel="canonical" href={normalizedCanonical} />
  <link rel="stylesheet" href="/styles/foebe-shell.css" />

  <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
  <link href="/favicon.ico" rel="icon" type="image/x-icon" />
  <link href="/images/favicon-96x96.png" rel="icon" sizes="96x96" type="image/png" />
  <link href="/images/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
  <link href="/site.webmanifest" rel="manifest" />

  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDesc ?? description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={normalizedCanonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={twitterTitle ?? ogTitle ?? title} />
  <meta name="twitter:description" content={twitterDesc ?? ogDesc ?? description} />
  <meta name="twitter:image" content={twitterImage ?? ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="//cloud.umami.is" />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400;1,600&family=Montserrat:wght@700&family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <slot name="head" />
</head>
<body>
  <div id="stateOverlay"></div>
  <slot />

  <script is:inline src="/scripts/foebe-shared.js"></script>
  {umamiWebsiteId && (
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id={umamiWebsiteId}></script>
  )}
  <script is:inline defer src="/foebe-shell.js"></script>
</body>
</html>
