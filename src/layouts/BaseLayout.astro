---
import FoebeFallbackShell from "../components/FoebeFallbackShell.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  bodyClass?: string;
  robots?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = "https://maisonfoebe.fr/images/og-foebe.jpg",
  ogImageAlt = "Maison Foébé, espace structuré du self-care",
  twitterTitle = ogTitle,
  twitterDescription = ogDescription,
  bodyClass = "",
  robots = "index,follow",
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html data-theme="night" lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Anti-FOUC thème : doit rester avant les feuilles de style. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("foebeTheme");
          if (saved === "day" || saved === "night") {
            document.documentElement.setAttribute("data-theme", saved);
            return;
          }
        } catch (error) {}

        var prefersLight =
          window.matchMedia &&
          window.matchMedia("(prefers-color-scheme: light)").matches;

        document.documentElement.setAttribute(
          "data-theme",
          prefersLight ? "day" : "night",
        );
      })();
    </script>

    <!-- Watchdog du Shell : conserve la navigation de secours si le Shell échoue. -->
    <script is:inline id="foebe-shell-fallback-guard">
      (function () {
        var root = document.documentElement;
        root.classList.add("foebe-shell-loading");

        window.__foebeShellWatchdog = window.setTimeout(function () {
          if (!root.classList.contains("foebe-shell-ready")) {
            root.classList.remove("foebe-shell-loading");
            root.classList.add("foebe-shell-failed");

            try {
              window.dispatchEvent(new CustomEvent("foebe:shell-failed"));
            } catch (error) {}
          }
        }, 3000);
      })();
    </script>

    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="Maison Foébé" />
    <meta property="og:locale" content="fr_FR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={twitterTitle} />
    <meta name="twitter:description" content={twitterDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script
      is:inline
      defer
      data-website-id="f25f1f6a-c967-4466-a744-e78fa7f4932f"
      src="https://cloud.umami.is/script.js"
    ></script>

    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      ></script>
    )}

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400;1,600&family=Poppins:wght@400;500;600&family=Montserrat:wght@700&display=swap"
    />

    <slot name="head" />
  </head>

  <body class={bodyClass}>
    <FoebeFallbackShell />
    <slot />

    <!-- Fichier global déjà présent dans public/ : ne pas le remplacer. -->
    <script is:inline src="/foebe-shell.js"></script>
  </body>
</html>
