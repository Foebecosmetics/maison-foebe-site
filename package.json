{
  "name": "maison-foebe-site-public",
  "private": true,
  "engines": { "node": ">=22" },
  "type": "module",
  "version": "1.3.0",
  "scripts": {
    "prebuild": "node scripts/build-shell.mjs && node scripts/generate-sitemap.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "audit": "node scripts/audit-built-site.mjs",
    "validate": "npm run build && npm run audit",
    "deploy": "npm run validate && wrangler deploy",
    "deploy:preview": "npm run validate && wrangler versions upload"
  },
  "dependencies": {
    "astro": "6.4.8"
  },
  "devDependencies": {
    "esbuild": "0.27.7",
    "wrangler": "4.105.0"
  }
}
